async function loadCat(endpoint,rowId,type,genreId=null){const c=document.getElementById(rowId);if(!c)return;c.innerHTML='';for(let i=0;i<6;i++){const s=document.createElement('div');s.className='skeleton card';c.appendChild(s)}let url=`${BASE}${endpoint}?api_key=${API_KEY}&language=en-US`;if(genreId)url+=`&with_genres=${genreId}`;const d=await fetc(url);c.innerHTML='';if(!d?.results)return;for(const item of d.results.slice(0,18)){item.media_type=type;item._cert=await getCert(item);createCard(item,c)}}
