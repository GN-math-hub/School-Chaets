// ── Cache / Fetch ────────────────────────────────────────────────────────
async function fetc(url){const c=cache.get(url);if(c&&Date.now()-c.t<CACHE_TTL)return c.d;try{const r=await fetch(url);const d=await r.json();cache.set(url,{d,t:Date.now()});return d}catch{return null}}

