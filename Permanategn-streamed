  TRENDING_SEARCHES.forEach(q=>{const chip=document.createElement('div');chip.className='search-chip';chip.innerHTML=`<span class="chip-icon"><i class="fa-solid fa-fire-alt"></i></span>${q}`;chip.onclick=()=>runSearch(q);tc.appendChild(chip)});
  const rc=document.getElementById('recentChips'),rs=document.getElementById('recentSearches');rc.innerHTML='';
  if(recentSearches.length>0){rs.style.display='block';recentSearches.slice(0,8).forEach(q=>{const chip=document.createElement('div');chip.className='recent-chip';chip.innerHTML=`<i class="fa-regular fa-clock" style="font-size:12px;flex-shrink:0"></i><span style="flex:1">${q}</span><button class="chip-del" onclick="event.stopPropagation();removeRecentSearch('${q.replace(/'/g,"\'")}')"><i class="fa-solid fa-xmark"></i></button>`;chip.onclick=e=>{if(e.target.closest('.chip-del'))return;runSearch(q)};rc.appendChild(chip)})}else rs.style.display='none';
  const cg=document.getElementById('categoryGrid');cg.innerHTML='';
  CATEGORIES.forEach(cat=>{const card=document.createElement('div');card.className='cat-card';card.innerHTML=`<div class="cat-card-overlay" style="background:${cat.gradient}"></div><div class="cat-card-label"><i class="${cat.icon}"></i>${cat.label}</div>`;card.onclick=()=>searchByGenre(cat.genreId,cat.label);cg.appendChild(card)});
}
function removeRecentSearch(q){recentSearches=recentSearches.filter(r=>r!==q);localStorage.setItem('gnRecentSearches',JSON.stringify(recentSearches));buildDefaultView()}
function clearRecentSearches(){recentSearches=[];localStorage.setItem('gnRecentSearches',JSON.stringify(recentSearches));buildDefaultView()}
function addRecentSearch(q){recentSearches=recentSearches.filter(r=>r!==q);recentSearches.unshift(q);if(recentSearches.length>12)recentSearches=recentSearches.slice(0,12);localStorage.setItem('gnRecentSearches',JSON.stringify(recentSearches))}
async function runSearch(q){if(!q.trim())return;addRecentSearch(q.trim());document.getElementById('searchOverlayInput').value=q;document.getElementById('searchOverlayClear').classList.add('vis');currentSearchFilter='all';showResultsView();await fetchSearchResults(q)}
async function searchByGenre(genreId,label){showResultsView();const meta=document.getElementById('searchResultsMeta');meta.innerHTML=`<strong>${label}</strong><span>Loading…</span>`;const grid=document.getElementById('searchResultsGrid');grid.innerHTML=`<div class="search-loading"><div class="spin"></div><span>Finding ${label} titles…</span></div>`;try{const[d1,d2]=await Promise.all([fetc(`${BASE}/discover/movie?api_key=${API_KEY}&with_genres=${genreId}&sort_by=popularity.desc`),fetc(`${BASE}/discover/tv?api_key=${API_KEY}&with_genres=${genreId}&sort_by=popularity.desc`)]);const items=[...(d1?.results||[]).map(i=>({...i,media_type:'movie'})),...(d2?.results||[]).map(i=>({...i,media_type:'tv'}))];items.sort((a,b)=>b.popularity-a.popularity);meta.innerHTML=`<strong>${label}</strong><span>${items.length} titles</span>`;renderSearchGrid(items.slice(0,40),grid)}catch{grid.innerHTML='<div class="search-empty"><h3>Oops</h3><p>Failed to load</p></div>'}}
async function fetchSearchResults(q,filter='all'){const grid=document.getElementById('searchResultsGrid');const meta=document.getElementById('searchResultsMeta');grid.innerHTML=`<div class="search-loading"><div class="spin"></div><span>Searching…</span></div>`;meta.innerHTML=`<span>Searching for <strong>${q}</strong>…</span>`;try{const d=await fetc(`${BASE}/search/multi?api_key=${API_KEY}&query=${encodeURIComponent(q)}`);let results=(d?.results||[]).filter(i=>i.media_type==='movie'||i.media_type==='tv');const total=results.length;if(filter==='movie')results=results.filter(i=>i.media_type==='movie');else if(filter==='tv')results=results.filter(i=>i.media_type==='tv');meta.innerHTML=`<strong style="color:var(--text);font-size:16px;font-weight:800">"${q}"</strong><span>${total} result${total!==1?'s':''}</span><button class="search-filter-chip ${filter==='all'?'on':''}" onclick="setSearchFilter('all','${q}')">All</button><button class="search-filter-chip ${filter==='movie'?'on':''}" onclick="setSearchFilter('movie','${q}')">Movies</button><button class="search-filter-chip ${filter==='tv'?'on':''}" onclick="setSearchFilter('tv','${q}')">TV Shows</button>`;if(!results.length){grid.innerHTML=`<div class="search-empty"><h3>No Results</h3><p>Try a different title</p></div>`;return}renderSearchGrid(results.slice(0,48),grid)}catch{grid.innerHTML='<div class="search-empty"><h3>Error</h3><p>Search failed — try again</p></div>';meta.innerHTML=''}}
function setSearchFilter(f,q){currentSearchFilter=f;fetchSearchResults(q,f)}
function renderSearchGrid(items,grid){grid.innerHTML='';items.forEach((item,idx)=>{const inL=myList.some(i=>i.id===item.id);const poster=item.poster_path?`${IMG}w342${item.poster_path}`:FB_P;const year=(item.release_date||item.first_air_date||'').slice(0,4);const rating=item.vote_average?item.vote_average.toFixed(1):'—';const card=document.createElement('div');card.className='search-result-card';card.style.animationDelay=`${Math.min(idx*20,300)}ms`;window[`iref_${item.id}`]=item;card.innerHTML=`<img src="${poster}" alt="${item.title||item.name}" loading="lazy" onerror="this.src='${FB_P}'"><div class="search-result-overlay"><div class="search-result-title">${item.title||item.name}</div><div class="search-result-meta"><i class="fa-solid fa-star" style="color:#ffd700;font-size:9px"></i>${rating}${year?`<span>· ${year}</span>`:''}<span style="margin-left:auto;opacity:.7">${item.media_type==='tv'?'TV':'Film'}</span></div></div><button class="search-result-add ${inL?'on':''}" onclick="event.stopPropagation();handleListToggle(${item.id})">${inL?'<i class="fa-solid fa-check"></i>':'<i class="fa-solid fa-plus"></i>'}</button>`;card.addEventListener('click',e=>{if(e.target.closest('.search-result-add'))return;closeSearchOverlay();setTimeout(()=>openDetails(item),200)});grid.appendChild(card)})}
document.getElementById('searchOverlayInput').addEventListener('input',function(){const q=this.value.trim();document.getElementById('searchOverlayClear').classList.toggle('vis',q.length>0);clearTimeout(searchDebounceTimer);if(!q){showDefaultView();return}showResultsView();document.getElementById('searchResultsMeta').innerHTML=`<span>Searching…</span>`;document.getElementById('searchResultsGrid').innerHTML=`<div class="search-loading"><div class="spin"></div></div>`;searchDebounceTimer=setTimeout(()=>fetchSearchResults(q,currentSearchFilter),380)});
document.getElementById('searchOverlayInput').addEventListener('keydown',function(e){if(e.key==='Escape'){closeSearchOverlay();return}if(e.key==='Enter'){const q=this.value.trim();if(q)runSearch(q)}});
document.getElementById('searchOverlay').addEventListener('click',function(e){if(e.target===this)closeSearchOverlay()});

