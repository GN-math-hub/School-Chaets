  font-family:'Outfit',sans-serif;
  transition:all .2s;
  text-transform:uppercase;
  letter-spacing:.5px;
  touch-action:manipulation;
  min-height:48px;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
