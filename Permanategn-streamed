function setHero(idx){heroIdx=idx;const item=heroItems[idx];if(!item)return;const isTv=!!item.first_air_date,title=item.title||item.name,year=(item.release_date||item.first_air_date||'').slice(0,4),rating=item.vote_average?.toFixed(1)||'';const bg=document.getElementById('heroBg');bg.style.opacity='0';setTimeout(()=>{bg.style.backgroundImage=`url(${IMG}original${item.backdrop_path})`;bg.style.opacity='1'},200);document.getElementById('heroTitle').textContent=title;document.getElementById('heroOverview').textContent=item.overview||'';document.getElementById('heroEyebrow').innerHTML=`<i class="fa-solid fa-fire-alt"></i> #${idx+1} ${isTv?'Series':'Movie'}`;document.getElementById('heroMeta').innerHTML=`<span style="color:#46d369;font-weight:800">${Math.floor(Math.random()*15+83)}% Match</span><span>${year}</span>${rating?`<span><i class="fa-solid fa-star" style="color:#ffd700;font-size:12px"></i> ${rating}</span>`:''}<span style="background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);padding:2px 10px;border-radius:5px;font-weight:700;font-size:11px" id="heroCert">NR</span><span>${isTv?'Series':'Movie'}</span>`;getCert(item).then(c=>{const el=document.getElementById('heroCert');if(el)el.textContent=c});document.querySelectorAll('.hero-dot').forEach((d,i)=>d.classList.toggle('on',i===idx));item.media_type=isTv?'tv':'movie';window._hero=item;const inList=myList.some(i=>i.id===item.id);const btn=document.getElementById('heroListBtn');btn.innerHTML=inList?'<i class="fa-solid fa-check"></i>':'<i class="fa-solid fa-plus"></i>';btn.classList.toggle('active',inList)}
function heroPlay(){const item=window._hero;if(!item)return;addHistory(item);addContinue(item,0,7200);openPlayer(item.id,item.media_type==='tv',1,1)}
function heroMoreInfo(){if(window._hero)openDetails(window._hero)}
function heroToggleList(){const item=window._hero;if(!item)return;toggleList(item);const inList=myList.some(i=>i.id===item.id);const btn=document.getElementById('heroListBtn');btn.innerHTML=inList?'<i class="fa-solid fa-check"></i>':'<i class="fa-solid fa-plus"></i>';btn.classList.toggle('active',inList)}
async function heroTrailer(){const item=window._hero;if(!item)return;const type=item.media_type==='tv'?'tv':'movie';const d=await fetc(`${BASE}/${type}/${item.id}/videos?api_key=${API_KEY}`);const t=d?.results?.find(v=>v.type==='Trailer'&&v.site==='YouTube')||d?.results?.[0];if(t?.key){window.open(`https://www.youtube.com/watch?v=${t.key}`,'_blank');toast('🎬 Opening trailer…','suc')}else toast('No trailer available','err')}

// ── Cert ─────────────────────────────────────────────────────────────────
async function getCert(item){try{const isTv=item.media_type==='tv'||!!item.first_air_date;if(isTv){const d=await fetc(`${BASE}/tv/${item.id}/content_ratings?api_key=${API_KEY}`);return d?.results?.find(r=>r.iso_3166_1==='US')?.rating||'NR'}else{const d=await fetc(`${BASE}/movie/${item.id}/release_dates?api_key=${API_KEY}`);return d?.results?.find(r=>r.iso_3166_1==='US')?.release_dates?.[0]?.certification||'NR'}}catch{return'NR'}}

