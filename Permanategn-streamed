function timeAgo(date){const diff=Date.now()-date.getTime(),m=Math.floor(diff/60000),h=Math.floor(diff/3600000),d=Math.floor(diff/86400000);if(m<1)return'Just now';if(m<60)return`${m}m ago`;if(h<24)return`${h}h ago`;if(d<7)return`${d}d ago`;return date.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}

