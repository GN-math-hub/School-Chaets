  to{transform:translateY(0);opacity:1}
}

.pc-title{
  font-size:13px;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:1px;
  margin-bottom:16px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.pc-title svg{
  width:16px;
  height:16px;
  color:var(--text-secondary);
}

.pc-close{
  background:none;
  border:none;
  color:var(--text-muted);
  cursor:pointer;
  font-size:18px;
  padding:8px;
  width:36px;
  height:36px;
  display:flex;
  align-items:center;
  justify-content:center;
  touch-action:manipulation;
}

.pc-close:hover{
  color:var(--text);
}

.pc-grid{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:16px;
}

.pc-section h4{
  font-size:11px;
  font-weight:700;
  text-transform:uppercase;
  color:var(--text-muted);
  letter-spacing:1px;
  margin-bottom:10px;
  display:flex;
  align-items:center;
  gap:6px;
}

.pc-section h4 svg{
  width:14px;
  height:14px;
}

.pc-options{
  display:flex;
  flex-direction:column;
  gap:6px;
}

.pc-opt{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:10px 12px;
  background:var(--surface-light);
  border-radius:8px;
  border:1px solid var(--border);
  cursor:pointer;
  transition:all .2s;
  font-size:13px;
  touch-action:manipulation;
  min-height:40px;
}

.pc-opt:hover{
  border-color:rgba(255,255,255,.2);
}

.pc-opt.selected{
  border-color:var(--primary);
  background:rgba(229,9,20,.08);
}

.pc-opt-check{
  color:var(--primary);
  font-size:16px;
  opacity:0;
}

.pc-opt.selected .pc-opt-check{
  opacity:1;
}

.subtitle-track{
  display:flex;
  align-items:center;
  gap:10px;
  padding:10px 12px;
  background:var(--surface-light);
  border-radius:8px;
  border:1px solid var(--border);
  cursor:pointer;
  transition:all .2s;
  font-size:13px;
  margin-bottom:6px;
  touch-action:manipulation;
  min-height:40px;
}

.subtitle-track:hover{
  border-color:rgba(255,255,255,.2);
}

.subtitle-track.selected{
  border-color:#4ade80;
  background:rgba(74,222,128,.06);
}

.subtitle-flag{
  font-size:18px;
  flex-shrink:0;
}

.subtitle-name{
  flex:1;
}

.subtitle-check{
  color:#4ade80;
  font-size:16px;
  opacity:0;
}

.subtitle-track.selected .subtitle-check{
  opacity:1;
}

.quality-badge{
  font-size:9px;
  font-weight:800;
  padding:2px 6px;
  border-radius:4px;
  background:linear-gradient(135deg,#6366f1,#4f46e5);
  color:#fff;
  margin-left:6px;
}

/* Mood Results */
#moodResultsSection{
  display:none;
  padding:0 4% 40px;
}

.mood-results-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:20px;
}

.mood-results-title{
  font-size:20px;
  font-weight:800;
}

.mood-results-close{
  background:var(--surface-light);
  border:1px solid var(--border);
  color:var(--text);
  padding:10px 16px;
  border-radius:18px;
  font-size:12px;
  font-weight:600;
  cursor:pointer;
  font-family:'Outfit',sans-serif;
  transition:all .2s;
  touch-action:manipulation;
  min-height:40px;
  display:flex;
  align-items:center;
  gap:6px;
}

.mood-results-close:hover{
  border-color:var(--primary);
