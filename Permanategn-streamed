}

function heroToggleList(){
  const item=window._heroItem;
  if(!item)return;
  toggleMyList(item);
  const inList=myList.some(i=>i.id===item.id);
  const btn=document.getElementById('heroWatchlistBtn');
  btn.innerHTML=inList?'<svg width="20" height="20"><use href="#icon-check"/></svg>':'<svg width="20" height="20"><use href="#icon-plus"/></svg>';
