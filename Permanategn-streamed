async function loadEmbeddedApp(pageId,loadingId,frameId,url,loadedFlag){
  document.getElementById(pageId).classList.add('open');document.body.classList.add('locked');
  if(!window[loadedFlag]){
    try{const res=await fetch(url);if(!res.ok)throw new Error('Failed to load');const html=await res.text();const frame=document.getElementById(frameId);frame.srcdoc=html;frame.style.display='block';document.getElementById(loadingId).style.display='none';window[loadedFlag]=true}
    catch(err){document.getElementById(loadingId).innerHTML=`<span class="load-icon"><i class="fa-solid fa-circle-exclamation"></i></span><p>Failed to load</p><small>${err.message}</small><button onclick="window['${loadedFlag}']=false;loadEmbeddedApp('${pageId}','${loadingId}','${frameId}','${url}','${loadedFlag}')" style="margin-top:12px;background:var(--surface3);color:var(--text);border:1px solid var(--border);padding:9px 20px;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;font-family:sans-serif">Retry</button>`}
  }
}
