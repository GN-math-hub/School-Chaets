async function loadEmbeddedApp(pageId,loadingId,frameId,url,loadedFlag){
  document.getElementById(pageId).classList.add('open');document.body.classList.add('locked');
  if(!window[loadedFlag]){
    try{const res=await fetch(url);if(!res.ok)throw new Error('Failed to load');const html=await res.text();const frame=document.getElementById(frameId);frame.srcdoc=html;frame.style.display='block';document.getElementById(loadingId).style.display='none';window[loadedFlag]=true}
    catch(err){document.getElementById(loadingId).innerHTML=`<span class="load-icon" style="color:var(--red)"><i class="fa-solid fa-circle-exclamation"></i></span><p>Failed to load</p><small>${err.message}</small><button onclick="window['${loadedFlag}']=false;loadEmbeddedApp('${pageId}','${loadingId}','${frameId}','${url}','${loadedFlag}')" style="margin-top:14px;background:linear-gradient(135deg,var(--red),var(--red-dark));color:#fff;border:none;padding:10px 24px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:sans-serif;box-shadow:0 4px 16px var(--red-glow)">Retry</button>`}
  }
}
