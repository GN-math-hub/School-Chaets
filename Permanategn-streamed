// ── Startup tip ──────────────────────────────────────────────────────────
function dismissTip(){var el=document.getElementById('startupTip');if(!el)return;localStorage.setItem('gnTipDone','1');el.style.transition='opacity .4s';el.style.opacity='0';setTimeout(()=>{try{el.remove()}catch(e){}},400)}
function startTipCountdown(){var n=10,el=document.getElementById('tipCountNum'),ring=document.getElementById('tipRingCircle'),circ=113.1;if(!el||!ring)return;var iv=setInterval(()=>{n--;if(el)el.textContent=n;if(ring)ring.style.strokeDashoffset=circ*((10-n)/10);if(n<=0){clearInterval(iv);dismissTip()}},1000)}
if(localStorage.getItem('gnTipDone')){var _t=document.getElementById('startupTip');if(_t){_t.style.display='none';try{_t.remove()}catch(e){}}}
if(!localStorage.getItem('gnTipDone'))startTipCountdown();

// ── Constants ────────────────────────────────────────────────────────────
