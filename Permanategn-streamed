// ── Details modal ────────────────────────────────────────────────────────
async function openDetails(item){
  currentItem=item;scrollPos=window.pageYOffset;
  const posterUrl=item.backdrop_path?`${IMG}original${item.backdrop_path}`:(item.poster_path?`${IMG}w780${item.poster_path}`:FB_B);
  const pi=document.getElementById('detailsPoster');pi.src=posterUrl;pi.onerror=()=>pi.src=FB_B;
  document.getElementById('detailsTitle').textContent=item.title||item.name;
  document.getElementById('detailsYear').textContent=(item.release_date||item.first_air_date||'').slice(0,4);
  document.getElementById('detailsOverview').textContent=item.overview||'No overview available.';
  document.getElementById('detailsCert').textContent=item._cert||'NR';
  document.getElementById('detailsMatch').textContent=`${Math.floor(Math.random()*15+83)}% Match`;
  document.getElementById('detailsGenre').textContent=await getGenreNames(item.genre_ids);
  updateDetailsListBtn();
  await Promise.all([loadCast(item),loadRecs(item),loadPAW(item)]);
  const isTv=item.media_type==='tv'||!!item.first_air_date;
  if(isTv){document.getElementById('epSection').style.display='block';await loadSeasons(item.id)}
  else document.getElementById('epSection').style.display='none';
  document.body.classList.add('locked');document.getElementById('detailsModal').classList.add('open');
}
function closeDetails(){document.getElementById('detailsModal').classList.remove('open');document.body.classList.remove('locked');document.getElementById('detailsPoster').src='';currentItem=null;setTimeout(()=>window.scrollTo(0,scrollPos),10)}
function closeDetailsBd(e){if(e.target===document.getElementById('detailsModal'))closeDetails()}
