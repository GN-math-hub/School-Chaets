document.addEventListener('keydown',e=>{
  if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.tagName==='SELECT'){if(e.key==='Escape')e.target.blur();return}
  switch(e.key){
    case't':case'T':toggleTheme();break;
    case'g':case'G':e.preventDefault();document.getElementById('settingsModal').classList.contains('open')?closeSettings():openSettings();break;
    case'/':e.preventDefault();openSearchOverlay();break;
    case'Escape':
      if(document.getElementById('settingsModal').classList.contains('open'))closeSettings();
      else if(document.getElementById('playerControls').classList.contains('open'))closePlayerControls();
      else if(document.getElementById('profilesModal').classList.contains('open'))closeProfiles();
      else if(document.getElementById('playerModal').classList.contains('open'))closePlayer();
      else if(document.getElementById('detailsModal').classList.contains('open'))closeDetails();
      else if(document.getElementById('gnSportsPage').classList.contains('open'))closeEmbeddedApp('gnSportsPage');
      else if(document.getElementById('gnTVPage').classList.contains('open'))closeEmbeddedApp('gnTVPage');
      else if(document.getElementById('gnMusicPage').classList.contains('open'))closeEmbeddedApp('gnMusicPage');
      break;
  }
});

