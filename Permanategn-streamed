}

.mood-results-close svg{
  width:14px;
  height:14px;
}

.mood-results-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(155px,1fr));
  gap:14px;
}

/* Player */
#playerModal{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.97);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:20000;
  padding:20px;
  opacity:0;
  transition:opacity .3s;
}

#playerModal.active{
  display:flex;
  opacity:1;
}

#playerContent{
