<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Launcher</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#111;
    font-family:Arial, sans-serif;
    color:white;
    flex-direction:column;
}

button{
    padding:14px 32px;
    font-size:18px;
    border:none;
    border-radius:8px;
    background:#00aaff;
    color:white;
    cursor:pointer;
    transition:0.2s;
    margin:8px;
}

button:hover{
    background:#008ecc;
}

.spinner{
    width:50px;
    height:50px;
    border:6px solid #333;
    border-top:6px solid #00aaff;
    border-radius:50%;
    animation:spin 1s linear infinite;
    margin-top:20px;
    display:none;
}

@keyframes spin{
    0%{transform:rotate(0deg);}
    100%{transform:rotate(360deg);}
}
</style>
</head>

<body>

<h2>Launch Page</h2>
<button onclick="launch('https://raw.githubusercontent.com/GN-math-hub/School-Chaets/main/star-streamonmobile.html')">Launch Star stream for mobile (beta)</button>
<button onclick="launch('https://raw.githubusercontent.com/GN-math-hub/School-Chaets/main/gnstreamnoaddsorpopups.html')">Launch star Stream</button>

<div class="spinner" id="spinner"></div>

<script>
async function launch(url){
    document.getElementById("spinner").style.display="block";

    const newTab = window.open("about:blank","_blank");

    newTab.document.write(`
    <!DOCTYPE html>
    <html>
    <head>
    <title>Loading...</title>
    <style>
    body{
        margin:0;
        background:#111;
        display:flex;
        justify-content:center;
        align-items:center;
        height:100vh;
        flex-direction:column;
        font-family:Arial;
        color:white;
    }

    .spinner{
        width:60px;
        height:60px;
        border:6px solid #333;
        border-top:6px solid #00aaff;
        border-radius:50%;
        animation:spin 1s linear infinite;
        margin-bottom:20px;
    }

    @keyframes spin{
        0%{transform:rotate(0deg);}
        100%{transform:rotate(360deg);}
    }
    </style>
    </head>
    <body>

    <div class="spinner"></div>
    <div>Loading...</div>

    </body>
    </html>
    `);

    try{
        const response = await fetch(url);
        const html = await response.text();

        newTab.document.open();
        newTab.document.write(html);
        newTab.document.close();
    }catch(err){
        newTab.document.body.innerHTML="<h2>Failed to load content</h2>";
        console.error(err);
    }
}
</script>

</body>
</html>
