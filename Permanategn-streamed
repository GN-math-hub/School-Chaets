async function loadMore(){if(isLoadingMore||discoverLoaded>=600)return;isLoadingMore=true;const btn=document.getElementById('loadMoreBtn');btn.disabled=true;const grid=document.getElementById('discoverGrid');try{let eps=[`/movie/popular?api_key=${API_KEY}&language=en-US&page=${discoverPage}`,`/tv/popular?api_key=${API_KEY}&language=en-US&page=${discoverPage}`,`/movie/top_rated?api_key=${API_KEY}&language=en-US&page=${discoverPage}`,`/tv/top_rated?api_key=${API_KEY}&language=en-US&page=${discoverPage}`];const picked=eps.sort(()=>.5-Math.random()).slice(0,2);const results=await Promise.all(picked.map(u=>fetc(`${BASE}${u}`)));const seen=new Set();let items=[];results.forEach(d=>{if(d?.results)items=items.concat(d.results)});items=items.filter(i=>{if(seen.has(i.id))return false;seen.add(i.id);return true});for(const item of items.slice(0,20)){if(discoverLoaded>=600)break;item.media_type=item.first_air_date?'tv':'movie';item._cert=await getCert(item);createCard(item,grid);discoverLoaded++}discoverPage++;document.getElementById('discoverCount').textContent=`${discoverLoaded}+`;if(discoverLoaded>=600){btn.innerHTML='<span>All Loaded</span>';btn.disabled=true}else{btn.innerHTML=`<i class="fa-solid fa-arrow-down"></i> <span>Load More (${discoverLoaded} / 600)</span>`;btn.disabled=false}}catch{toast('Failed to load more');btn.disabled=false}finally{isLoadingMore=false}}

