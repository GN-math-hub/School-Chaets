  #searchOverlayInput{font-size:16px}
  #categoryGrid{grid-template-columns:repeat(auto-fill,minmax(135px,1fr));gap:8px}
}
</style>
</head>
<body>

<!-- STARTUP TIP -->
<div id="startupTip">
