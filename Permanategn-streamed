function startTipCountdown(){var n=10,el=document.getElementById('tipCountNum'),ring=document.getElementById('tipRingCircle'),circ=113.1;if(!el||!ring)return;var iv=setInterval(()=>{n--;if(el)el.textContent=n;if(ring)ring.style.strokeDashoffset=circ*((10-n)/10);if(n<=0){clearInterval(iv);dismissTip()}},1000)}
