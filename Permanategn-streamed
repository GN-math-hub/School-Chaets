  opacity:1;
}

.mini-ctrl-btn{
  width:40px;
  height:40px;
  background:rgba(255,255,255,.12);
  border:1px solid rgba(255,255,255,.18);
  border-radius:50%;
  color:#fff;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
  transition:all .2s;
  backdrop-filter:blur(4px);
  touch-action:manipulation;
}

.mini-ctrl-btn:hover{
  background:var(--primary);
  border-color:var(--primary);
  transform:scale(1.08);
}

.mini-ctrl-btn svg{
  width:18px;
  height:18px;
}

.mini-player-title{
  position:absolute;
  bottom:0;
  left:0;
  right:0;
  padding:18px 10px 7px;
  background:linear-gradient(to top,rgba(0,0,0,.9),transparent);
  font-size:10px;
  font-weight:600;
  color:#fff;
  white-space:nowrap;
  overflow:hidden;
