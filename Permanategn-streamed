  .details-actions{flex-direction:column;gap:8px}
  .btn-d{width:100%;justify-content:center}
  #detailsBody{padding:0 18px 18px}
  .ep-section,.recs-section,.paw-section{padding-left:18px;padding-right:18px}
  .ep-card{flex-direction:column}
  .ep-thumb{flex:none;width:100%;height:0;padding-bottom:56.25%;position:relative}
  .ep-thumb img{position:absolute;inset:0;width:100%;height:100%}
  .pc-grid{grid-template-columns:1fr}
  .profiles-grid{grid-template-columns:repeat(3,1fr)}
  #miniPlayer{width:216px;height:122px;bottom:72px;right:10px}
