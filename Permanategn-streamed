            <option value="dark">Dark</option>
            <option value="light">Light</option>
          </select>
        </div>
      </div>
      <div class="settings-sec">
        <div class="settings-sec-title">Playback</div>
        <div class="settings-row">
          <div class="settings-row-lbl"><div class="settings-row-name">Default Server</div><div class="settings-row-desc">Which streaming server to use by default</div></div>
          <select class="settings-select" id="settingsServerSelect" onchange="changeServer(this.value)">
            <option value="1">AutoEmbed Test</option><option value="2">AutoEmbed Player</option>
            <option value="3">Star-Stream FLixy</option><option value="4">VidSrc.to</option>
            <option value="5">2Embed</option><option value="6">MultiEmbed</option>
            <option value="7">Embed.su</option><option value="8">VidSrc.xyz</option>
            <option value="9">VidSrc.me</option><option value="10">VidSrc.in</option>
          </select>
        </div>
        <div class="settings-row">
          <div class="settings-row-lbl"><div class="settings-row-name">Autoplay Next Episode</div><div class="settings-row-desc">Automatically play the next episode</div></div>
          <label class="toggle"><input type="checkbox" id="autoplayToggle" checked onchange="saveSetting('autoplay',this.checked)"><span class="toggle-track"></span></label>
        </div>
