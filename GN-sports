<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>STAR·TV — Live Sports</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --accent:#1a6fd4;--accent-dim:rgba(26,111,212,0.15);--accent-glow:rgba(26,111,212,0.4);--accent-hover:#3d8ef0;
  --bg:#060b14;--bg2:#0a1120;--bg3:#0f1a2e;--bg4:#152038;--bg5:#1c2a45;
  --border:rgba(100,160,255,0.08);--border2:rgba(100,160,255,0.14);
  --white:#e8f0ff;--grey:rgba(180,210,255,0.55);--grey2:rgba(180,210,255,0.3);
  --radius:10px;--nav-w:240px;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden}
body{font-family:'Sora',sans-serif;background:var(--bg);color:var(--white);display:flex;flex-direction:column;}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bg5);border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:var(--accent)}

/* ── TOP NAV ─────────────────────── */
#topnav{flex-shrink:0;height:62px;display:flex;align-items:center;padding:0 1.8rem;gap:1.5rem;background:var(--bg2);border-bottom:1px solid var(--border);z-index:200;}
.logo{font-size:1.35rem;font-weight:800;letter-spacing:-.04em;cursor:pointer;color:var(--white);display:flex;align-items:center;gap:.45rem;user-select:none;}
.logo-dot{color:#5aaeff}
.top-nav-links{display:flex;gap:.2rem;margin-left:1.2rem;}
.tnl{background:none;border:none;font-family:'Sora',sans-serif;font-size:.8rem;font-weight:600;color:var(--grey);padding:.38rem .85rem;border-radius:6px;cursor:pointer;transition:all .15s;}
.tnl:hover{color:var(--white);background:rgba(100,160,255,.07)}
.tnl.active{color:var(--white);background:rgba(100,160,255,.1)}
.top-right{margin-left:auto;display:flex;align-items:center;gap:.7rem;}
.search-wrap{position:relative;display:flex;align-items:center;}
.search-ico{position:absolute;left:.7rem;color:var(--grey2);pointer-events:none;}
.search-box{background:var(--bg3);border:1px solid var(--border2);border-radius:8px;color:var(--white);font-family:'Sora',sans-serif;font-size:.8rem;padding:.42rem .9rem .42rem 2.2rem;width:220px;outline:none;transition:border-color .2s,box-shadow .2s;}
.search-box:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-dim)}
.search-box::placeholder{color:var(--grey2)}
.live-pill{display:flex;align-items:center;gap:.35rem;background:rgba(26,111,212,.12);border:1px solid rgba(26,111,212,.35);border-radius:100px;padding:.22rem .8rem;font-size:.63rem;font-weight:700;color:#5aaeff;letter-spacing:.09em;flex-shrink:0;}
.dot-blink{width:5px;height:5px;border-radius:50%;background:#5aaeff;animation:blink 1.4s infinite;flex-shrink:0;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}

/* ── APP BODY ─────────────────────── */
#appBody{flex:1;display:flex;overflow:hidden;}

/* ── SIDEBAR ─────────────────────── */
#sidebar{width:var(--nav-w);flex-shrink:0;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;padding:1rem .75rem 2rem;}
.sb-label{font-size:.58rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--grey2);padding:.9rem .65rem .4rem;margin-top:.4rem;}
.sb-link{display:flex;align-items:center;gap:.65rem;background:none;border:none;border-left:3px solid transparent;font-family:'Sora',sans-serif;font-size:.8rem;font-weight:600;color:var(--grey);padding:.52rem .65rem;border-radius:8px;cursor:pointer;width:100%;text-align:left;transition:all .15s;}
.sb-link:hover{color:var(--white);background:rgba(100,160,255,.07)}
.sb-link.active{color:#5aaeff;background:var(--accent-dim);border-left-color:var(--accent);}
.sb-icon{width:18px;height:18px;flex-shrink:0;display:flex;align-items:center;justify-content:center;opacity:.75;}
.sb-link.active .sb-icon{opacity:1}
.sb-text{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-count{flex-shrink:0;font-size:.6rem;font-weight:700;background:var(--bg4);color:var(--grey);padding:.1rem .45rem;border-radius:100px;font-family:'JetBrains Mono',monospace;}
.sb-link.active .sb-count{background:rgba(26,111,212,.2);color:#5aaeff}

/* source pills in sidebar */
.src-pill{display:inline-flex;align-items:center;gap:.28rem;font-size:.52rem;font-weight:800;letter-spacing:.06em;padding:.15rem .42rem;border-radius:3px;text-transform:uppercase;border:1px solid transparent;font-family:'JetBrains Mono',monospace;white-space:nowrap;}
.src-pill.sk {background:rgba(26,111,212,.18);color:#5aaeff;border-color:rgba(26,111,212,.3);}
.src-pill.ws {background:rgba(0,200,130,.12);color:#00c88a;border-color:rgba(0,200,130,.28);}
.src-pill.sr {background:rgba(180,80,220,.14);color:#b450dc;border-color:rgba(180,80,220,.28);}
.src-pill.dl {background:rgba(240,160,0,.12);color:#f0a020;border-color:rgba(240,160,0,.28);}
.src-pill.multi{background:rgba(255,255,255,.06);color:var(--grey);border-color:var(--border2);}

.src-legend{display:flex;flex-direction:column;gap:.5rem;padding:.4rem .65rem .8rem;}
.src-legend-row{display:flex;align-items:center;gap:.55rem;font-size:.68rem;color:var(--grey);}

/* ── CONTENT ─────────────────────── */
#content{flex:1;overflow-y:auto;display:flex;flex-direction:column;}

/* ── HERO ─────────────────────────── */
#hero{position:relative;height:420px;flex-shrink:0;display:flex;align-items:flex-end;overflow:hidden;}
#heroBg{position:absolute;inset:0;background-size:cover;background-position:center;filter:blur(26px) brightness(.14) saturate(1.5);transform:scale(1.1);transition:background-image .7s ease;}
.hero-vignette{position:absolute;inset:0;background:linear-gradient(to top,var(--bg) 0%,rgba(6,11,20,.5) 50%,transparent 100%),linear-gradient(to right,rgba(6,11,20,.96) 0%,transparent 62%);}
.hero-glow{position:absolute;inset:0;background:radial-gradient(ellipse at 15% 80%,rgba(26,111,212,.22) 0%,transparent 55%)}
.hero-inner{position:relative;z-index:2;padding:2.5rem 2.5rem 3rem;max-width:600px;}
.hero-badges{display:flex;gap:.5rem;align-items:center;margin-bottom:.9rem;flex-wrap:wrap}
.h-badge{display:inline-flex;align-items:center;gap:.35rem;font-size:.6rem;font-weight:800;letter-spacing:.1em;padding:.2rem .65rem;border-radius:4px;}
.h-badge.live{background:var(--accent);color:#fff}
.h-badge.cat{background:rgba(100,160,255,.1);color:var(--grey);border:1px solid var(--border2)}
.hero-title{font-size:2.6rem;font-weight:800;line-height:1.07;letter-spacing:-.03em;margin-bottom:.75rem;}
.hero-teams{display:flex;align-items:center;gap:1rem;margin-bottom:.85rem;}
/* ★ SHARP hero badges — no blur, no radius */
.hero-badge-img{width:52px;height:52px;object-fit:contain;filter:drop-shadow(0 2px 10px rgba(0,0,0,.7));}
.hero-vs{font-size:.68rem;font-weight:800;color:var(--grey2);letter-spacing:.12em}
.hero-meta{font-size:.78rem;color:var(--grey);margin-bottom:1.8rem;display:flex;gap:.7rem;align-items:center;flex-wrap:wrap}
.hero-sep{width:3px;height:3px;border-radius:50%;background:var(--grey2);flex-shrink:0;}
.hero-actions{display:flex;gap:.7rem;flex-wrap:wrap}
.btn-play{display:inline-flex;align-items:center;gap:.5rem;background:var(--accent);color:#fff;font-family:'Sora',sans-serif;font-size:.86rem;font-weight:700;padding:.7rem 1.75rem;border-radius:8px;border:none;cursor:pointer;transition:all .2s;}
.btn-play:hover{background:var(--accent-hover);transform:translateY(-1px);box-shadow:0 8px 28px var(--accent-glow)}
.btn-outline{display:inline-flex;align-items:center;gap:.5rem;background:rgba(100,160,255,.08);color:var(--white);font-family:'Sora',sans-serif;font-size:.86rem;font-weight:600;padding:.7rem 1.4rem;border-radius:8px;border:1px solid var(--border2);cursor:pointer;transition:all .2s;backdrop-filter:blur(8px);}
.btn-outline:hover{background:rgba(100,160,255,.15);transform:translateY(-1px)}

/* ── ROWS ─────────────────────────── */
.rows-area{padding:1.5rem 2rem 4rem;display:flex;flex-direction:column;gap:2.5rem;}
.row-section{display:flex;flex-direction:column;gap:.85rem;}
.row-hdr{display:flex;align-items:center;justify-content:space-between;gap:1rem;}
.row-title{font-size:.95rem;font-weight:700;display:flex;align-items:center;gap:.55rem;letter-spacing:-.01em}
.row-title-icon{width:18px;height:18px;color:#5aaeff;flex-shrink:0;}
.row-count{font-size:.7rem;color:var(--grey);font-weight:500;white-space:nowrap;}
.row-count span{color:#5aaeff;font-weight:700}
.row-scroll{display:flex;gap:.85rem;overflow-x:auto;padding-bottom:.5rem;scrollbar-width:none;}
.row-scroll::-webkit-scrollbar{display:none}

/* ── CARDS ─────────────────────────── */
.match-card{flex-shrink:0;width:252px;background:var(--bg2);border-radius:12px;border:1px solid var(--border);cursor:pointer;overflow:hidden;position:relative;transition:transform .22s cubic-bezier(.34,1.56,.64,1),box-shadow .22s,border-color .22s;}
.match-card:hover{transform:translateY(-5px) scale(1.025);border-color:var(--accent);box-shadow:0 18px 50px rgba(0,0,0,.75),0 0 0 1px rgba(26,111,212,.35);}

/* card poster — NO blur on bg, dark overlay only */
.mc-poster{position:relative;height:140px;background:linear-gradient(135deg,var(--bg3) 0%,var(--bg4) 100%);overflow:hidden;display:flex;align-items:center;justify-content:center;}
/* subtle ambient background — very low opacity, NO blur */
.mc-poster-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.08;}
/* dark gradient over ambient so badges pop */
.mc-poster-shade{position:absolute;inset:0;background:linear-gradient(to top,rgba(6,11,20,.6) 0%,transparent 60%);}
.mc-teams-row{position:relative;z-index:2;display:flex;align-items:center;justify-content:center;gap:1.1rem;}
/* ★ SHARP card badges */
.mc-badge{width:56px;height:56px;object-fit:contain;image-rendering:auto;filter:drop-shadow(0 2px 8px rgba(0,0,0,.55));}
.mc-vs{font-size:.62rem;font-weight:800;color:var(--grey2);letter-spacing:.12em}
.mc-placeholder{color:rgba(100,160,255,.2);position:relative;z-index:2;}
.mc-live-tag{position:absolute;top:8px;left:8px;z-index:3;background:var(--accent);color:#fff;font-size:.53rem;font-weight:800;letter-spacing:.1em;padding:.14rem .45rem;border-radius:3px;}
.mc-src-wrap{position:absolute;top:8px;right:8px;z-index:3;display:flex;gap:3px;}
.mc-body{padding:.7rem .95rem .95rem;}
.mc-title{font-size:.8rem;font-weight:700;line-height:1.32;margin-bottom:.32rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.mc-meta{font-size:.66rem;color:var(--grey);display:flex;gap:.45rem;align-items:center;flex-wrap:wrap}
.mc-dot{width:2px;height:2px;border-radius:50%;background:var(--grey2);flex-shrink:0}
.mc-pop{display:inline-flex;align-items:center;gap:.2rem;color:#f0c040;font-size:.6rem;font-weight:700}

/* ── PLAYER ─────────────────────────── */
#playerModal{display:none;position:fixed;inset:0;background:#000;z-index:2000;flex-direction:column;}
#playerModal.open{display:flex}
#playerHeader{display:flex;align-items:center;justify-content:space-between;background:rgba(6,11,20,.98);border-bottom:1px solid var(--border);padding:.85rem 1.5rem;flex-shrink:0;gap:1rem;flex-wrap:wrap;}
.ph-left{display:flex;align-items:center;gap:.8rem;}
.ph-live{background:var(--accent);color:#fff;font-size:.56rem;font-weight:800;letter-spacing:.1em;padding:.18rem .52rem;border-radius:3px;flex-shrink:0;}
.ph-title{font-size:.9rem;font-weight:700}
.ph-sub{font-size:.68rem;color:var(--grey);margin-top:1px}
.ph-right{display:flex;align-items:center;gap:.65rem;flex-wrap:wrap;}
.stream-btns{display:flex;gap:.4rem;flex-wrap:wrap;max-width:600px;}
.stream-btn{background:var(--bg3);border:1px solid var(--border2);color:var(--grey);font-family:'JetBrains Mono',monospace;font-size:.65rem;font-weight:700;padding:.3rem .7rem;border-radius:5px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:.3rem;}
.stream-btn:hover,.stream-btn.active{background:var(--accent-dim);border-color:var(--accent);color:#5aaeff}
.ph-close{background:var(--bg3);border:1px solid var(--border);color:var(--grey);font-family:'Sora',sans-serif;font-size:.76rem;font-weight:600;padding:.38rem 1rem;border-radius:6px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:.4rem;flex-shrink:0;}
.ph-close:hover{background:var(--bg4);color:var(--white)}
#playerFrame{flex:1;border:none;width:100%;background:#000;}

/* ── DETAIL MODAL ─────────────────────── */
#detailBg{display:none;position:fixed;inset:0;background:rgba(0,5,15,.87);backdrop-filter:blur(10px);z-index:1000;align-items:center;justify-content:center;padding:2rem;}
#detailBg.open{display:flex;animation:fadeIn .18s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
#detailModal{background:var(--bg2);border-radius:14px;width:100%;max-width:640px;border:1px solid var(--border2);box-shadow:0 40px 100px rgba(0,0,0,.92);animation:modalUp .28s cubic-bezier(.34,1.2,.64,1);max-height:88vh;overflow-y:auto;}
@keyframes modalUp{from{opacity:0;transform:scale(.93) translateY(20px)}to{opacity:1;transform:none}}
.dm-art{position:relative;height:210px;background:linear-gradient(135deg,var(--bg3),var(--bg4));overflow:hidden;display:flex;align-items:center;justify-content:center;}
#dmBg{position:absolute;inset:0;background-size:cover;background-position:center;filter:blur(24px) brightness(.12) saturate(1.5);transform:scale(1.1);}
.dm-art-fade{position:absolute;inset:0;background:linear-gradient(to top,var(--bg2) 0%,transparent 55%)}
.dm-teams-wrap{position:relative;z-index:1;display:flex;align-items:center;gap:1.8rem;}
/* ★ SHARP modal badges */
.dm-badge{width:80px;height:80px;object-fit:contain;image-rendering:auto;filter:drop-shadow(0 4px 16px rgba(0,0,0,.65));}
.dm-vs-text{font-size:.85rem;font-weight:800;color:var(--grey2);letter-spacing:.12em}
.dm-placeholder{color:rgba(100,160,255,.18);}
.dm-close{position:absolute;top:1rem;right:1rem;z-index:2;background:rgba(6,11,20,.75);border:1px solid var(--border2);color:var(--grey);width:32px;height:32px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;}
.dm-close:hover{background:rgba(100,160,255,.12);color:var(--white)}
.dm-body{padding:1.4rem 1.8rem 2rem;}
.dm-tags{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.8rem;}
.dm-tag{display:inline-flex;align-items:center;gap:.3rem;font-size:.58rem;font-weight:800;letter-spacing:.09em;padding:.18rem .55rem;border-radius:4px;}
.dm-tag.live{background:var(--accent);color:#fff}
.dm-tag.cat{background:var(--bg4);color:var(--grey);border:1px solid var(--border)}
.dm-title{font-size:1.5rem;font-weight:800;letter-spacing:-.025em;margin-bottom:.5rem;line-height:1.15}
.dm-date{font-size:.76rem;color:#5aaeff;font-weight:600;margin-bottom:1rem;display:flex;align-items:center;gap:.4rem;}
.dm-stats{display:flex;gap:1.5rem;margin-bottom:1.4rem;flex-wrap:wrap}
.dm-stat{display:flex;flex-direction:column;gap:.18rem;}
.dm-stat-label{font-size:.58rem;font-weight:700;letter-spacing:.1em;color:var(--grey2);text-transform:uppercase}
.dm-stat-val{font-size:.82rem;font-weight:600}
.dm-actions{display:flex;gap:.6rem;flex-wrap:wrap;margin-bottom:1.5rem}
.dm-btn{display:inline-flex;align-items:center;gap:.45rem;font-family:'Sora',sans-serif;font-size:.8rem;font-weight:700;padding:.6rem 1.25rem;border-radius:8px;cursor:pointer;transition:all .15s;border:1px solid transparent;}
.dm-btn.play{background:var(--accent);color:#fff;border-color:var(--accent)}
.dm-btn.play:hover{background:var(--accent-hover);box-shadow:0 6px 22px var(--accent-glow)}
.dm-btn.sec{background:var(--bg4);color:var(--white);border-color:var(--border2)}
.dm-btn.sec:hover{background:var(--bg5)}
.dm-btn.added{border-color:var(--accent);color:#5aaeff;background:var(--accent-dim)}
.streams-section{border-top:1px solid var(--border);padding-top:1.2rem;}
.streams-title{font-size:.8rem;font-weight:700;margin-bottom:.75rem;display:flex;align-items:center;gap:.45rem;}
.stream-option{display:flex;align-items:center;gap:.75rem;padding:.65rem .9rem;border-radius:8px;cursor:pointer;border:1px solid var(--border);background:var(--bg3);margin-bottom:.45rem;transition:all .15s;}
.stream-option:hover{border-color:var(--accent);background:var(--accent-dim)}
.so-icon{width:32px;height:32px;border-radius:6px;background:var(--bg4);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#5aaeff;}
.so-info{flex:1}
.so-name{font-size:.78rem;font-weight:700}
.so-sub{font-size:.65rem;color:var(--grey);margin-top:1px}
.so-play{background:var(--accent);color:#fff;border:none;font-family:'Sora',sans-serif;font-size:.7rem;font-weight:700;padding:.3rem .85rem;border-radius:5px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;gap:.3rem;transition:background .15s;}
.so-play:hover{background:var(--accent-hover)}

/* ── LOADING STATES ─────────────────── */
.loading-progress{padding:2rem 2.5rem;display:flex;flex-direction:column;gap:.6rem;}
.lp-title{font-size:.78rem;font-weight:700;color:var(--white);margin-bottom:.3rem;}
.lp-row{display:flex;align-items:center;gap:.65rem;font-size:.75rem;color:var(--grey);}
.lp-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.lp-dot.spin-d{border:2px solid rgba(26,111,212,.2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;}
.lp-dot.done{background:#00c882;}
.lp-dot.fail{background:#e05a5a;}
.spinner{width:20px;height:20px;border:2px solid rgba(26,111,212,.15);border-top:2px solid var(--accent);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0;}
@keyframes spin{to{transform:rotate(360deg)}}
.empty-state{padding:4rem 2rem;text-align:center;color:var(--grey);display:flex;flex-direction:column;align-items:center;gap:.8rem;}
.empty-icon{color:rgba(100,160,255,.15);}

/* ── TOAST ─────────────────────────── */
#toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(100px);background:var(--bg3);border:1px solid var(--border2);border-radius:var(--radius);padding:.75rem 1.3rem;display:flex;align-items:center;gap:.6rem;box-shadow:0 16px 48px rgba(0,0,0,.7);z-index:3000;transition:transform .3s ease;font-size:.8rem;font-weight:600;white-space:nowrap;}
#toast.show{transform:translateX(-50%) translateY(0)}
.toast-ico{color:#5aaeff;}

@media(max-width:900px){#sidebar{display:none}.rows-area{padding:1rem 1rem 4rem}}
@media(max-width:600px){
  #topnav{padding:0 1rem}.search-box{width:130px}.top-nav-links{display:none}
  #hero{height:300px}.hero-inner{padding:1.2rem 1rem 2rem}.hero-title{font-size:1.55rem}
}
</style>
</head>
<body>
<nav id="topnav">
  <span class="logo" onclick="resetView()">
    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#5aaeff" stroke-width="2.5"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
    STAR<span class="logo-dot">·</span>SPORTS
  </span>
  <div class="top-nav-links">
    <button class="tnl active" id="tnl-live" onclick="setNav('live',this)">Live Now</button>
    <button class="tnl" id="tnl-popular" onclick="setNav('popular',this)">Featured</button>
    <button class="tnl" id="tnl-mylist" onclick="setNav('mylist',this)">My List</button>
  </div>
  <div class="top-right">
    <div class="search-wrap">
      <svg class="search-ico" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input class="search-box" id="searchInput" type="text" placeholder="Search matches…"/>
    </div>
    <div class="live-pill"><span class="dot-blink"></span>LIVE</div>
  </div>
</nav>

<div id="appBody">
  <aside id="sidebar">
    <div class="sb-label">Sports</div>
    <button class="sb-link active" id="sb-all" onclick="setSport('all',this)">
      <span class="sb-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
      <span class="sb-text">All Sports</span>
      <span class="sb-count" id="cnt-all">—</span>
    </button>
    <div id="sportLinks"></div>
    <div class="sb-label">Library</div>
    <button class="sb-link" onclick="setNav('mylist',document.getElementById('tnl-mylist'))">
