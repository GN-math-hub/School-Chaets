<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<title>Star Sports</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{overflow-x:hidden;max-width:100vw}
body{font-family:'Outfit',-apple-system,sans-serif;background:#03080f;color:#fff;min-height:100vh;line-height:1.6;-webkit-font-smoothing:antialiased}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes livePulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.7)}}
@keyframes starGlow{0%,100%{filter:drop-shadow(0 0 8px rgba(0,212,255,.5))}50%{filter:drop-shadow(0 0 22px rgba(0,212,255,.95))}}

#starSportsPage{display:flex;flex-direction:column;height:100vh;font-family:'Barlow Condensed','Outfit',sans-serif;overflow:hidden;background:#03080f}
#starSportsPage *{box-sizing:border-box}

/* HEADER */
.ss-header{height:64px;background:linear-gradient(to right,#020a18,#051428,#020a18);border-bottom:2px solid #0077e6;display:flex;align-items:center;padding:0 24px;gap:20px;flex-shrink:0;z-index:10;box-shadow:0 2px 28px rgba(0,119,230,.35)}
.ss-logo{font-family:'Barlow Condensed','Bebas Neue',sans-serif;font-size:28px;font-weight:900;letter-spacing:3px;text-transform:uppercase;background:linear-gradient(135deg,#38bdf8,#0ea5e9,#00d4ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:starGlow 3s ease-in-out infinite}
.ss-live-dot{width:8px;height:8px;background:#38bdf8;border-radius:50%;box-shadow:0 0 10px #38bdf8,0 0 22px rgba(56,189,248,.5);animation:livePulse 1.2s ease-in-out infinite;flex-shrink:0}
.ss-time{font-size:12px;color:rgba(56,189,248,.55);font-family:sans-serif;font-weight:600;letter-spacing:.5px}
.ss-server-picker{display:flex;align-items:center;gap:8px;background:rgba(56,189,248,.06);border:1px solid rgba(0,119,230,.4);border-radius:8px;padding:6px 12px;margin-left:auto}
.ss-server-label{font-size:10px;font-weight:800;color:rgba(56,189,248,.45);text-transform:uppercase;letter-spacing:1px;white-space:nowrap;font-family:sans-serif}
.ss-server-select{background:transparent;color:#38bdf8;border:none;font-size:12px;font-weight:700;cursor:pointer;outline:none;font-family:sans-serif;min-width:110px}
.ss-server-select option,.ss-server-select optgroup{background:#06101c;color:#fff}

/* TABS */
.ss-tabs{display:flex;gap:4px;padding:14px 24px 10px;background:#03080f;border-bottom:1px solid rgba(56,189,248,.07);overflow-x:auto;flex-shrink:0;scrollbar-width:none}
.ss-tabs::-webkit-scrollbar{display:none}
.ss-tab{background:rgba(56,189,248,.05);border:1px solid rgba(56,189,248,.1);color:rgba(56,189,248,.5);padding:7px 18px;border-radius:4px;font-size:12px;font-weight:800;cursor:pointer;white-space:nowrap;transition:all .2s;font-family:sans-serif;text-transform:uppercase;letter-spacing:1px;flex-shrink:0}
.ss-tab:hover{background:rgba(0,119,230,.2);border-color:rgba(0,119,230,.5);color:rgba(255,255,255,.85)}
.ss-tab.on{background:linear-gradient(135deg,#0077e6,#005bb3);border-color:#38bdf8;color:#fff;box-shadow:0 2px 14px rgba(0,119,230,.5),0 0 0 1px rgba(56,189,248,.2)}

/* BODY */
.ss-body{flex:1;display:flex;overflow:hidden}

/* SIDEBAR */
.ss-sidebar{width:320px;flex-shrink:0;background:#060e1a;border-right:1px solid rgba(56,189,248,.08);display:flex;flex-direction:column;overflow:hidden}
.ss-sidebar-head{padding:14px 18px 10px;font-size:10px;font-weight:800;color:rgba(56,189,248,.4);text-transform:uppercase;letter-spacing:2px;border-bottom:1px solid rgba(56,189,248,.05);display:flex;align-items:center;justify-content:space-between}
.ss-count{background:rgba(0,119,230,.2);color:#38bdf8;padding:2px 8px;border-radius:3px;font-size:10px;border:1px solid rgba(56,189,248,.2)}
.ss-channels{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:#0077e6 transparent}
.ss-channels::-webkit-scrollbar{width:3px}
.ss-channels::-webkit-scrollbar-thumb{background:linear-gradient(#38bdf8,#0055b3);border-radius:2px}
.ss-channel{padding:14px 18px;cursor:pointer;border-left:3px solid transparent;border-bottom:1px solid rgba(56,189,248,.04);transition:all .18s;display:flex;gap:12px;align-items:flex-start}
.ss-channel:hover{background:rgba(56,189,248,.05);border-left-color:rgba(0,119,230,.5)}
.ss-channel.active{background:rgba(0,119,230,.1);border-left-color:#38bdf8}
.ss-ch-icon{width:38px;height:38px;border-radius:8px;background:rgba(56,189,248,.08);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;border:1px solid rgba(56,189,248,.12)}
.ss-ch-info{flex:1;min-width:0}
.ss-ch-sport{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;color:#38bdf8;margin-bottom:3px}
.ss-ch-title{font-size:13px;font-weight:700;color:#fff;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:sans-serif}
.ss-ch-live{display:inline-flex;align-items:center;gap:4px;background:linear-gradient(135deg,#0077e6,#005bb3);color:#fff;font-size:9px;font-weight:900;padding:2px 7px;border-radius:3px;letter-spacing:1px;margin-top:4px}
.ss-ch-live::before{content:'';width:5px;height:5px;background:#38bdf8;border-radius:50%;animation:livePulse 1s infinite}
.ss-loading{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;color:rgba(56,189,248,.4)}
.ss-spinner{width:36px;height:36px;border:2.5px solid rgba(56,189,248,.1);border-top-color:#38bdf8;border-radius:50%;animation:spin .8s linear infinite}
.ss-empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;color:rgba(56,189,248,.3);padding:30px;text-align:center}
.ss-empty i{font-size:40px;color:rgba(0,119,230,.35)}
.ss-empty h3{font-size:16px;font-weight:800;color:rgba(56,189,248,.55);font-family:sans-serif}

/* PLAYER */
.ss-player{flex:1;display:flex;flex-direction:column;background:#020810;overflow:hidden}
.ss-player-wrap{position:relative;width:100%;background:#020810;flex-shrink:0}
.ss-player-wrap::before{content:'';display:block;padding-top:56.25%}
.ss-player-wrap iframe,.ss-player-wrap #ssPlayerInner{position:absolute;inset:0;width:100%;height:100%;border:none}
#ssPlayerInner{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;background:radial-gradient(ellipse at center,#071830 0%,#020810 100%)}
.ss-player-logo{font-family:'Barlow Condensed','Bebas Neue',sans-serif;font-size:58px;font-weight:900;letter-spacing:6px;background:linear-gradient(135deg,#38bdf8,#0ea5e9,#00d4ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;filter:drop-shadow(0 0 32px rgba(0,119,230,.6))}
.ss-player-stars{font-size:22px;letter-spacing:6px;opacity:.55}
.ss-player-hint{font-size:14px;color:rgba(56,189,248,.4);font-family:sans-serif;font-weight:600;letter-spacing:.5px}
.ss-now-playing{padding:16px 20px;background:#060e1a;border-top:2px solid #0077e6;flex-shrink:0;box-shadow:0 -2px 18px rgba(0,119,230,.15)}
.ss-now-title{font-size:18px;font-weight:900;color:#fff;font-family:'Barlow Condensed','Outfit',sans-serif;letter-spacing:1px;line-height:1.2}
.ss-now-meta{display:flex;align-items:center;gap:12px;margin-top:6px;flex-wrap:wrap}
.ss-now-sport-badge{background:linear-gradient(135deg,#0077e6,#005bb3);color:#fff;font-size:10px;font-weight:900;padding:3px 10px;border-radius:3px;text-transform:uppercase;letter-spacing:1.5px}
.ss-now-time{font-size:12px;color:rgba(56,189,248,.5);font-family:sans-serif;font-weight:600}
.ss-stream-btns{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
.ss-stream-btn{background:rgba(56,189,248,.06);border:1px solid rgba(56,189,248,.12);color:rgba(56,189,248,.65);padding:6px 14px;border-radius:4px;font-size:11px;font-weight:700;cursor:pointer;font-family:sans-serif;transition:all .2s;letter-spacing:.5px}
.ss-stream-btn:hover{background:rgba(0,119,230,.25);border-color:rgba(56,189,248,.45);color:#fff}
.ss-stream-btn.on{background:linear-gradient(135deg,#0077e6,#005bb3);border-color:#38bdf8;color:#fff;box-shadow:0 2px 10px rgba(0,119,230,.45)}

/* MOBILE */
@media(max-width:768px){
  .ss-sidebar{width:100%;position:absolute;bottom:0;left:0;right:0;height:50%;border-right:none;border-top:1px solid rgba(56,189,248,.12);z-index:5;transform:translateY(100%);transition:transform .3s}
  .ss-sidebar.mob-open{transform:translateY(0)}
  .ss-player{position:absolute;top:64px;left:0;right:0;bottom:50%}
  .ss-mob-toggle{display:flex}
}
.ss-mob-toggle{display:none;background:linear-gradient(135deg,#0077e6,#005bb3);border:none;color:#fff;padding:8px 14px;border-radius:6px;font-size:12px;font-weight:800;cursor:pointer;font-family:sans-serif;align-items:center;gap:6px;letter-spacing:.5px;margin-left:8px}
</style>
</head>
<body>
<div id="starSportsPage">

  <div class="ss-header">
    <div class="ss-logo">⭐ STAR SPORTS</div>
    <div class="ss-live-dot"></div>
    <button class="ss-mob-toggle" onclick="document.getElementById('ssSidebar').classList.toggle('mob-open')"><i class="fa-solid fa-list"></i> Events</button>
    <div class="ss-server-picker">
      <label class="ss-server-label"><i class="fa-solid fa-server"></i> Server</label>
      <select id="ssServerSelect" class="ss-server-select" onchange="ssSetServer(this.value)">
        <option value="auto">&#x1F7E2; Auto (Best)</option>
        <optgroup label="embedme.top">
          <option value="alpha1">Alpha 1</option><option value="alpha2">Alpha 2</option><option value="alpha3">Alpha 3</option>
          <option value="beta1">Beta 1</option><option value="beta2">Beta 2</option>
          <option value="gamma1">Gamma 1</option><option value="gamma2">Gamma 2</option>
          <option value="delta1">Delta 1</option><option value="delta2">Delta 2</option>
        </optgroup>
        <optgroup label="Other Servers">
          <option value="streamedA">Streamed A</option><option value="streamedB">Streamed B</option>
          <option value="daddyhd1">DaddyHD 1</option><option value="daddyhd2">DaddyHD 2</option>
          <option value="sportstream">SportStream</option><option value="viprow">VIPRow</option><option value="bilasport">Bilasport</option>
        </optgroup>
      </select>
    </div>
    <div class="ss-time" id="ssSportsTime"></div>
  </div>

  <div class="ss-tabs">
    <button class="ss-tab on" onclick="ssFilter('all',this)">All Live</button>
    <button class="ss-tab" onclick="ssFilter('football',this)">⚽ Football</button>
    <button class="ss-tab" onclick="ssFilter('basketball',this)">🏀 Basketball</button>
    <button class="ss-tab" onclick="ssFilter('american-football',this)">🏈 NFL</button>
    <button class="ss-tab" onclick="ssFilter('hockey',this)">🏒 Hockey</button>
    <button class="ss-tab" onclick="ssFilter('baseball',this)">⚾ Baseball</button>
    <button class="ss-tab" onclick="ssFilter('tennis',this)">🎾 Tennis</button>
    <button class="ss-tab" onclick="ssFilter('motor-sports',this)">🏎️ Motor</button>
    <button class="ss-tab" onclick="ssFilter('mma',this)">🥊 MMA/Box</button>
    <button class="ss-tab" onclick="ssFilter('cricket',this)">🏏 Cricket</button>
    <button class="ss-tab" onclick="ssFilter('rugby',this)">🏉 Rugby</button>
  </div>

  <div class="ss-body">
    <div class="ss-sidebar" id="ssSidebar">
      <div class="ss-sidebar-head">
        <span>Live Events</span>
        <span class="ss-count" id="ssCount">—</span>
      </div>
      <div class="ss-channels" id="ssChannels">
        <div class="ss-loading"><div class="ss-spinner"></div><span style="font-size:13px;font-family:sans-serif">Loading live events…</span></div>
      </div>
    </div>

    <div class="ss-player">
      <div class="ss-player-wrap">
        <div id="ssPlayerInner">
          <div class="ss-player-stars">⭐ ⭐ ⭐</div>
          <div class="ss-player-logo">STAR SPORTS</div>
          <div class="ss-player-hint"><i class="fa-solid fa-hand-pointer"></i> Select an event to watch</div>
        </div>
        <iframe id="ssPlayerFrame" style="display:none" allowfullscreen allow="autoplay;fullscreen;encrypted-media;picture-in-picture"></iframe>
      </div>
      <div class="ss-now-playing" id="ssNowPlaying" style="display:none">
        <div class="ss-now-title" id="ssNowTitle">—</div>
        <div class="ss-now-meta">
          <span class="ss-now-sport-badge" id="ssNowSport">—</span>
          <span class="ss-now-time" id="ssNowTime"></span>
        </div>
        <div class="ss-stream-btns" id="ssStreamBtns"></div>
      </div>
    </div>
  </div>
</div>

<script>
const SS_BASE='https://streamed.pk';
const SPORT_ICONS={football:'⚽',basketball:'🏀','american-football':'🏈',hockey:'🏒',baseball:'⚾',tennis:'🎾','motor-sports':'🏎️',mma:'🥊',boxing:'🥊',cricket:'🏏',rugby:'🏉',golf:'⛳'};
let ssAllEvents=[],ssCurrentCat='all',ssActiveId=null,ssSportsLoaded=false,ssClockTimer=null,ssSportsLoading=false;

function startSsClock(){
  clearInterval(ssClockTimer);
  const el=document.getElementById('ssSportsTime');
  const t=()=>{if(el)el.textContent=new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'})};
  t();ssClockTimer=setInterval(t,1000);
}

async function ssFetch(url){
  const tries=[
    ()=>fetch(url,{headers:{Accept:'application/json'}}),
    ()=>fetch('https://api.allorigins.win/raw?url='+encodeURIComponent(url)),
    ()=>fetch('https://corsproxy.io/?'+encodeURIComponent(url)),
    ()=>fetch('https://proxy.cors.sh/'+url,{headers:{Accept:'application/json','x-cors-api-key':'temp_demo'}}),
  ];
  for(const fn of tries){try{const r=await fn();if(!r.ok)continue;const d=await r.json();if(d!=null)return d;}catch{}}
  return null;
}

async function loadSsEvents(){
  ssSportsLoading=true;setSsState('loading');
  let data=await ssFetch(SS_BASE+'/api/matches/live');
  if(!data||!Array.isArray(data)||!data.length)data=await ssFetch(SS_BASE+'/api/matches/all-today');
  if(!data||!Array.isArray(data)||!data.length){ssSportsLoaded=false;ssSportsLoading=false;setSsState('error');return;}
  ssAllEvents=data;ssSportsLoaded=true;ssSportsLoading=false;ssApplyFilter();
}

function setSsState(s){
  const ch=document.getElementById('ssChannels');
  if(s==='loading')ch.innerHTML='<div class="ss-loading"><div class="ss-spinner"></div><span style="font-size:13px;color:rgba(56,189,248,.5)">Fetching live events…</span></div>';
  else if(s==='error')ch.innerHTML='<div class="ss-empty"><i class="fa-solid fa-satellite-dish"></i><h3>Can\'t load events</h3><p style="font-size:12px;color:rgba(56,189,248,.3)">Check connection</p><button onclick="ssSportsLoaded=false;ssSportsLoading=false;loadSsEvents()" style="margin-top:14px;background:linear-gradient(135deg,#0077e6,#005bb3);color:#fff;border:none;padding:9px 22px;border-radius:4px;font-size:12px;font-weight:700;cursor:pointer"><i class="fa-solid fa-rotate-right"></i> Retry</button></div>';
}

function ssFilter(cat,btn){
  ssCurrentCat=cat;
  document.querySelectorAll('.ss-tab').forEach(t=>t.classList.remove('on'));
  if(btn)btn.classList.add('on');
  if(!ssSportsLoaded&&!ssSportsLoading){loadSsEvents();return;}
  ssApplyFilter();
}

function ssApplyFilter(){
  let ev=ssAllEvents;
  if(ssCurrentCat!=='all')ev=ssAllEvents.filter(e=>(e.category||'').toLowerCase()===ssCurrentCat);
  renderSsChannels(ev);
}

function renderSsChannels(events){
  const ch=document.getElementById('ssChannels');
  document.getElementById('ssCount').textContent=events.length;
  if(!events.length){ch.innerHTML='<div class="ss-empty"><i class="fa-solid fa-face-sad-tear"></i><h3>No events here</h3><p style="font-size:12px;color:rgba(56,189,248,.3)">Try All Live</p></div>';return;}
  ch.innerHTML='';
  events.forEach(ev=>{
    const cat=(ev.category||'other').toLowerCase();
    const icon=SPORT_ICONS[cat]||'🏆';
    const home=ev.teams?.home?.name||'',away=ev.teams?.away?.name||'';
    const matchup=home&&away?`${home} vs ${away}`:ev.title||'Live Event';
    const sub=(home&&away)?ev.title:'';
    const ds=ev.date?new Date(ev.date).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'';
    const src=(ev.sources||[]).length;
    const d=document.createElement('div');
    d.className='ss-channel'+(ssActiveId===ev.id?' active':'');
    d.innerHTML=`<div class="ss-ch-icon">${icon}</div><div class="ss-ch-info"><div class="ss-ch-sport">${ev.category||'Sport'}</div><div class="ss-ch-title" title="${matchup}">${matchup}</div>${sub?`<div style="font-size:10px;color:rgba(56,189,248,.3);margin-top:1px">${sub}</div>`:''}<div style="display:flex;align-items:center;gap:6px;margin-top:5px"><div class="ss-ch-live">LIVE</div>${ds?`<span style="font-size:10px;color:rgba(56,189,248,.35)">${ds}</span>`:''}${src?`<span style="font-size:10px;color:rgba(56,189,248,.5)">${src} src</span>`:''}</div></div>`;
    d.onclick=()=>ssPlay(ev,d);
    ch.appendChild(d);
  });
}

const SS_ALTS=[
  {name:'Alpha 1',c:'#38bdf8',u:(id,n)=>`https://embedme.top/embed/alpha/${id}/1`},
  {name:'Alpha 2',c:'#38bdf8',u:(id,n)=>`https://embedme.top/embed/alpha/${id}/2`},
  {name:'Alpha 3',c:'#38bdf8',u:(id,n)=>`https://embedme.top/embed/alpha/${id}/3`},
  {name:'Beta 1',c:'#0077e6',u:(id,n)=>`https://embedme.top/embed/beta/${id}/1`},
  {name:'Beta 2',c:'#0077e6',u:(id,n)=>`https://embedme.top/embed/beta/${id}/2`},
  {name:'Gamma 1',c:'#00d4ff',u:(id,n)=>`https://embedme.top/embed/gamma/${id}/1`},
  {name:'Gamma 2',c:'#00d4ff',u:(id,n)=>`https://embedme.top/embed/gamma/${id}/2`},
  {name:'Delta 1',c:'#0055b3',u:(id,n)=>`https://embedme.top/embed/delta/${id}/1`},
  {name:'Delta 2',c:'#0055b3',u:(id,n)=>`https://embedme.top/embed/delta/${id}/2`},
  {name:'Streamed A',c:'#3b82f6',u:(id,n)=>`https://streamed.su/watch/${id}/alpha/1`},
  {name:'Streamed B',c:'#3b82f6',u:(id,n)=>`https://streamed.su/watch/${id}/beta/1`},
  {name:'DaddyHD 1',c:'#93c5fd',u:(id,n)=>`https://dlhd.sx/embed/stream-${n||1}.php`},
  {name:'DaddyHD 2',c:'#93c5fd',u:(id,n)=>`https://dlhd.sx/embed/stream-${n||2}.php`},
  {name:'SportStream',c:'#bae6fd',u:(id,n)=>`https://sportstream.live/embed/${id}`},
  {name:'VIPRow',c:'#7dd3fc',u:(id,n)=>`https://viprow.me/embed/${id}`},
  {name:'Bilasport',c:'#38bdf8',u:(id,n)=>`https://bilasport.net/embed/${id}`},
];

function ssLoadEmbed(url){
  const fr=document.getElementById('ssPlayerFrame'),inn=document.getElementById('ssPlayerInner');
  inn.style.display='none';fr.src=url;fr.style.display='block';
}

function ssNoStreams(){
  const inn=document.getElementById('ssPlayerInner');
  inn.innerHTML='<i class="fa-solid fa-tv" style="font-size:40px;color:rgba(0,119,230,.35)"></i><span style="font-size:14px;color:rgba(56,189,248,.4);margin-top:8px">No streams available</span><span style="font-size:12px;color:rgba(56,189,248,.25)">Try an alternate server below</span>';
  inn.style.display='flex';
  const bc=document.getElementById('ssStreamBtns');
  bc.innerHTML='<span style="font-size:11px;color:rgba(56,189,248,.3)">Try alternate:</span> ';
  if(ssActiveId)SS_ALTS.forEach((s,i)=>{const b=document.createElement('button');b.className='ss-stream-btn ss-alt-btn';b.style.borderColor=s.c+'55';b.innerHTML=`<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${s.c};margin-right:4px;vertical-align:middle"></span>${s.name}`;b.onclick=()=>ssLoadAlt(ssActiveId,i);bc.appendChild(b);});
}

function ssLoadAlt(evId,idx,n){
  if(idx>=SS_ALTS.length){ssNoStreams();return;}
  const s=SS_ALTS[idx];
  document.querySelectorAll('.ss-alt-btn').forEach((b,i)=>b.classList.toggle('on',i===idx));
  const fr=document.getElementById('ssPlayerFrame'),inn=document.getElementById('ssPlayerInner');
  inn.style.display='none';fr.src=s.u(evId,n||1);fr.style.display='block';
}

function ssShowAlts(evId){
  const bc=document.getElementById('ssStreamBtns');
  if(bc.querySelector('.ss-alt-btn'))return;
  const lbl=document.createElement('div');
  lbl.style.cssText='width:100%;font-size:10px;color:rgba(56,189,248,.3);text-transform:uppercase;letter-spacing:1px;margin-top:6px;margin-bottom:2px';
  lbl.textContent='Alternate Servers';bc.appendChild(lbl);
  SS_ALTS.forEach((s,i)=>{const b=document.createElement('button');b.className='ss-stream-btn ss-alt-btn';b.style.borderColor=s.c+'55';b.title='Try '+s.name;b.innerHTML=`<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${s.c};margin-right:4px;vertical-align:middle"></span>${s.name}`;b.onclick=()=>ssLoadAlt(evId,i);bc.appendChild(b);});
}

async function ssPlay(ev,el){
  document.querySelectorAll('.ss-channel').forEach(c=>c.classList.remove('active'));
  if(el)el.classList.add('active');
  ssActiveId=ev.id;
  document.getElementById('ssSidebar').classList.remove('mob-open');
  const home=ev.teams?.home?.name||'',away=ev.teams?.away?.name||'';
  document.getElementById('ssNowTitle').textContent=(home&&away)?`${home} vs ${away}`:(ev.title||'Live Event');
  document.getElementById('ssNowSport').textContent=ev.category||'Sport';
  document.getElementById('ssNowTime').textContent=ev.date?new Date(ev.date).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'';
  document.getElementById('ssNowPlaying').style.display='block';
  document.getElementById('ssStreamBtns').innerHTML='<span style="font-size:11px;color:rgba(56,189,248,.4)"><i class="fa-solid fa-circle-notch fa-spin"></i> Finding streams…</span>';
  const fr=document.getElementById('ssPlayerFrame'),inn=document.getElementById('ssPlayerInner');
  inn.innerHTML='<div class="ss-spinner" style="width:44px;height:44px;border-width:3px"></div><span style="font-size:13px;color:rgba(56,189,248,.4);margin-top:8px">Connecting…</span>';
  inn.style.display='flex';fr.style.display='none';
  const sources=ev.sources||[];
  if(!sources.length){ssNoStreams();return;}
  const wt=(p,ms)=>Promise.race([p,new Promise(r=>setTimeout(()=>r(null),ms))]);
  const groups=await Promise.all(sources.map(s=>wt(ssFetch(`${SS_BASE}/api/stream/${s.source}/${s.id}`).then(d=>(Array.isArray(d)?d:[]).map(st=>({...st,_src:s.source}))),6000).then(r=>r||[])));
  const streams=groups.flat().filter(s=>s.embedUrl);
  if(!streams.length){ssNoStreams();return;}
  const bc=document.getElementById('ssStreamBtns');bc.innerHTML='';
  streams.forEach((s,i)=>{
    const lang=s.language||'',qual=s.hd?' HD':' SD',src=s._src||`src${i+1}`;
    const lbl=lang?lang+qual:`${src[0].toUpperCase()+src.slice(1)} #${s.streamNo||i+1}`;
    const b=document.createElement('button');
    b.className='ss-stream-btn'+(i===0?' on':'');
    b.innerHTML=(s.hd?'<i class="fa-solid fa-circle" style="color:#38bdf8;font-size:7px;vertical-align:middle;margin-right:3px"></i>':'')+lbl;
    b.onclick=()=>{document.querySelectorAll('.ss-stream-btn').forEach(x=>x.classList.remove('on'));b.classList.add('on');ssLoadEmbed(s.embedUrl);};
    bc.appendChild(b);
  });
  ssLoadEmbed(streams[0].embedUrl);
  ssShowAlts(ev.id);
}

function ssSetServer(v){
  const m={alpha1:0,alpha2:1,alpha3:2,beta1:3,beta2:4,gamma1:5,gamma2:6,delta1:7,delta2:8,streamedA:9,streamedB:10,daddyhd1:11,daddyhd2:12,sportstream:13,viprow:14,bilasport:15};
  if(v!=='auto'&&ssActiveId&&m[v]!=null)ssLoadAlt(ssActiveId,m[v]);
}

document.addEventListener('keydown',e=>{if(e.key==='Escape')document.getElementById('ssSidebar').classList.remove('mob-open');});
startSsClock();
loadSsEvents();
</script>
