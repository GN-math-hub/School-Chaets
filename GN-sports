<script>
// ══════════════════════════════════════════════
//  API ENDPOINTS
// ══════════════════════════════════════════════
const APIS = {
  // 1. Streamed.pk — primary live matches + stream embeds
  SK: {
    base:    'https://streamed.pk/api',
    img:     'https://streamed.pk',
    live:    '/matches/live',
    today:   '/matches/all-today',
    stream:  (src,id) => `/stream/${src}/${id}`,
    poster:  (p) => p ? (p.startsWith('/') ? 'https://streamed.pk'+p : 'https://streamed.pk/api/images/proxy/'+p) : '',
    badge:   (b) => b ? (b.startsWith('/') ? 'https://streamed.pk'+b : 'https://streamed.pk/api/images/badge/'+b) : '',
  },
  // 2. WeStream.su — same structure as streamed.pk, different pool
  WS: {
    base:    'https://westream.su',
    live:    '/matches/live',
    today:   '/matches',
    stream:  (src,id) => `/stream/${src}/${id}`,
    poster:  (p) => p ? (p.startsWith('/') ? 'https://westream.su'+p : 'https://westream.su/api/images/proxy/'+p) : '',
    badge:   (b) => b ? (b.startsWith('/') ? 'https://westream.su'+b : 'https://westream.su/api/images/badge/'+b) : '',
  },
  // 3. SportSRC — categories fetched individually
  SR: {
    base:    'https://api.sportsrc.org',
    cats:    ['football','basketball','mma','tennis','baseball','hockey','cricket','rugby','motorsport','golf','volleyball','handball'],
    matches: (cat) => `/?data=matches&category=${cat}`,
    detail:  (cat,id) => `/?data=detail&category=${cat}&id=${id}`,
  },
  // 4. DaddyLive — schedule → event list with channel stream IDs
  DL: {
    schedule: 'https://corsproxy.io/?url=https://dlstreams.top/schedule-json.php',
    streamUrl:(id) => `https://dlstreams.top/stream/stream-${id}.php`,
    logo:     (p) => p ? (p.startsWith('http') ? p : 'https://dlstreams.top/'+p) : '',
  },
};

// Proxy fallbacks for CORS
const PROXIES = [
  url => fetch(url, {headers:{Accept:'application/json'}}),
  url => fetch('https://corsproxy.io/?url='+encodeURIComponent(url)),
  url => fetch('https://api.allorigins.win/raw?url='+encodeURIComponent(url)),
];

async function tryFetch(url) {
  for (const fn of PROXIES) {
    try {
      const r = await fn(url);
      if (!r.ok) continue;
      const ct = r.headers.get('content-type')||'';
      if (ct.includes('json') || url.includes('sportsrc') || url.includes('westream') || url.includes('streamed')) {
        return await r.json();
      }
      const txt = await r.text();
      try { return JSON.parse(txt); } catch { return null; }
    } catch {}
  }
  return null;
}

// ══════════════════════════════════════════════
//  SPORT ICONS
// ══════════════════════════════════════════════
const SI = {
  football:      `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><circle cx="12" cy="12" r="10"/><path d="M5.2 5.2c3.8 3.8 3.8 9.8 0 13.6m13.6 0c-3.8-3.8-3.8-9.8 0-13.6M2 12h20M12 2v20"/></svg>`,
  basketball:    `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><circle cx="12" cy="12" r="10"/><path d="M4.93 4.93c4.08 4.08 4.08 10.07 0 14.14m14.14 0c-4.08-4.08-4.08-10.07 0-14.14M2 12h20M12 2v20"/></svg>`,
  tennis:        `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><circle cx="12" cy="12" r="10"/><path d="M18 5.46A7 7 0 0 0 6 17.54"/><path d="M6 6.46a7 7 0 0 0 12 11.08"/></svg>`,
  baseball:      `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><circle cx="12" cy="12" r="10"/><path d="M4.93 4.93c1.1 3.57 3.47 5.94 7.07 7.07m0 0c3.6 1.13 5.97 3.5 7.07 7.07"/></svg>`,
  cricket:       `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><path d="M4 20 20 4"/><path d="m14 6 4 4"/><path d="M4 20h4v-4"/></svg>`,
  rugby:         `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><ellipse cx="12" cy="12" rx="10" ry="7"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="5" x2="12" y2="19"/></svg>`,
  hockey:        `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><path d="M4 19h16M4 19c0-4 4-7 8-7s8 3 8 7M8 5l4 7 4-7"/></svg>`,
  fight:         `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8M6 14v0a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-3H6v3z"/></svg>`,
  mma:           `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8M6 14v0a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-3H6v3z"/></svg>`,
  'motor-sports':`<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><path d="M19 17H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2zM7 17v2M17 17v2"/></svg>`,
  motorsport:    `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><path d="M19 17H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2zM7 17v2M17 17v2"/></svg>`,
  golf:          `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><line x1="12" y1="2" x2="12" y2="22"/><path d="M12 2l5 5-5 3V2z" fill="currentColor" stroke="none"/><circle cx="12" cy="21" r="1"/></svg>`,
  volleyball:    `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><circle cx="12" cy="12" r="10"/><path d="M12 2C6.48 2 2 6.48 2 12"/><path d="M12 22c5.52 0 10-4.48 10-10"/><path d="M2.05 10H22"/></svg>`,
  handball:      `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>`,
  tv:            `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M8 20h8M12 18v2"/></svg>`,
  default:       `<svg width="SZ" height="SZ" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="SW"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
};
function icon(cat, sz=16) {
  const sw = sz<=18?2:1.5;
  const k = (cat||'').toLowerCase().replace(/[^a-z-]/g,'');
  return (SI[k]||SI.default).replace(/SZ/g,sz).replace(/SW/g,sw);
}
function cap(s) { return !s?'Sport':s.replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase()); }

// ══════════════════════════════════════════════
//  NORMALIZE — unified match object
// ══════════════════════════════════════════════
function mkMatch(o) {
  return {
    _id: '', _api: '', _raw: null,
    title: 'Unknown Match',
    category: 'other',
    date: new Date(),
    popular: false,
    poster: '',
    teams: { home:{name:'',badge:''}, away:{name:'',badge:''} },
    sources: [],   // streamed/westream-style sources
    _srCat: '',    // sportsrc category for detail fetch
    _dlId: '',     // daddylive channel id
    _apiLabel: '', // display label for source pill
    _multi: false,
    ...o
  };
}

function normalizeStreamed(m, api='sk') {
  const A = api==='sk' ? APIS.SK : APIS.WS;
  const label = api==='sk'?'sk':'ws';
  return mkMatch({
    _id:    label+'_'+m.id,
    _api:   label,
    _raw:   m,
    _apiLabel: api==='sk'?'SK':'WS',
    title:  m.title||'Unknown Match',
    category: (m.category||'other').toLowerCase(),
    date:   m.date ? new Date(m.date) : new Date(),
    popular: !!m.popular,
    poster: A.poster(m.poster),
    teams: {
      home: { name: m.teams?.home?.name||'', badge: A.badge(m.teams?.home?.badge) },
      away: { name: m.teams?.away?.name||'', badge: A.badge(m.teams?.away?.badge) },
    },
    sources: m.sources||[],
    _apiBase: A.base,
    _streamPath: A.stream,
  });
}

function normalizeSportsRC(m) {
  let cat = (m.category||'other').toLowerCase();
  if(cat==='motorsport') cat='motor-sports';
  const vsParts = (m.title||'').split(/\s+vs\.?\s+/i);
  let homeName='', awayName='';
  if(vsParts.length===2){homeName=vsParts[0].trim();awayName=vsParts[1].trim();}
  // unix timestamp or ms
  const d = m.date ? (m.date>1e10 ? new Date(m.date) : new Date(m.date*1000)) : new Date();
  return mkMatch({
    _id:    'sr_'+(m.id||Math.random()),
    _api:   'sr',
    _raw:   m,
    _apiLabel:'SR',
    _srCat: m.category,
    _srId:  m.id,
    title:  m.title||'Unknown Match',
    category: cat,
    date:   d,
    poster: m.poster||m.thumbnail||m.image||'',
    teams: {
      home:{name:homeName,badge:m.home_badge||''},
      away:{name:awayName,badge:m.away_badge||''},
    },
  });
}

function normalizeDaddy(ev, ch) {
  // ev = schedule event obj, ch = one channel from ev.channels
  const cat = guessCat(ev.event||'');
  return mkMatch({
    _id:    'dl_'+ch.channel_id,
    _api:   'dl',
    _raw:   {ev,ch},
    _apiLabel:'DL',
    _dlId:  ch.channel_id,
    title:  ev.event||ch.channel_name||'Live TV',
    category: cat,
    date:   parseDlTime(ev.time),
    poster: '',
    teams: { home:{name:'',badge:''}, away:{name:'',badge:APIS.DL.logo(ch.logo_url)} },
  });
}

// Merge / deduplicate
function mergeAll(...lists) {
  const out = [];
  const seen = new Map(); // normalised title → index in out
  for(const list of lists) {
    for(const m of list) {
      const key = m.title.toLowerCase().trim();
      if(seen.has(key)) {
        out[seen.get(key)]._multi = true;
        // attach extra sources
        if(m.sources?.length) out[seen.get(key)].sources.push(...m.sources);
      } else {
        seen.set(key, out.length);
        out.push({...m});
      }
    }
  }
  return out;
}

// ══════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════
function guessCat(title) {
  const t = title.toLowerCase();
  if(/nba|basketball|celtics|lakers|bulls|heat|warriors|bucks|nuggets/.test(t)) return 'basketball';
  if(/nfl|football|chiefs|eagles|cowboys|patriots|49ers|packers|touchdown/.test(t)) return 'football';
  if(/nhl|hockey|maple leafs|rangers|bruins|penguins|canadiens/.test(t)) return 'hockey';
  if(/mlb|baseball|yankees|dodgers|mets|cubs|red sox/.test(t)) return 'baseball';
  if(/ufc|mma|boxing|fight|bout|vs\.|bellator/.test(t)) return 'mma';
  if(/tennis|wimbledon|us open|french open|atp|wta/.test(t)) return 'tennis';
  if(/cricket|ipl|odi|test match/.test(t)) return 'cricket';
  if(/rugby|premier|six nations/.test(t)) return 'rugby';
  if(/formula|f1|nascar|motogp|race|grand prix/.test(t)) return 'motor-sports';
  if(/soccer|premier league|la liga|serie a|bundesliga|champions league|copa|euro|world cup/.test(t)) return 'football';
  return 'other';
}

function parseDlTime(timeStr) {
  if(!timeStr) return new Date();
  const [h,m] = timeStr.split(':').map(Number);
  const d = new Date();
  d.setHours(h||0,m||0,0,0);
  return d;
}

// ══════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════
let allMatches=[], filteredMatches=[], currentSport='all', navMode='live';
let heroMatch=null, detailMatch=null, myList=[];
try{myList=JSON.parse(localStorage.getItem('startv_ml')||'[]')}catch{}
function saveList(){try{localStorage.setItem('startv_ml',JSON.stringify(myList))}catch{}}

// ══════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════
async function init() {
  updateMyListCount();
  showLoadingProgress();

  const [sk, ws, sr, dl] = await Promise.allSettled([
    loadStreamed('sk'),
    loadStreamed('ws'),
    loadSportsRC(),
    loadDaddy(),
  ]);

  const skM = sk.status==='fulfilled' ? sk.value : [];
  const wsM = ws.status==='fulfilled' ? ws.value : [];
  const srM = sr.status==='fulfilled' ? sr.value : [];
  const dlM = dl.status==='fulfilled' ? dl.value : [];

  setDot('sk', skM.length>0?'done':'fail');
  setDot('ws', wsM.length>0?'done':'fail');
  setDot('sr', srM.length>0?'done':'fail');
  setDot('dl', dlM.length>0?'done':'fail');

  allMatches = mergeAll(skM, wsM, srM, dlM);
  document.getElementById('cnt-all').textContent = allMatches.length;
  buildSidebar(allMatches);
  applyFilter();

  const hero = allMatches.find(m=>m.popular) || allMatches[0];
  if(hero) setHero(hero);
}

function showLoadingProgress() {
  document.getElementById('rowsContainer').innerHTML = `
    <div class="loading-progress">
      <div class="lp-title">Connecting to 4 live sources…</div>
      <div class="lp-row"><span class="lp-dot spin-d" id="dot-sk"></span>Streamed.pk</div>
      <div class="lp-row"><span class="lp-dot spin-d" id="dot-ws"></span>WeStream.su</div>
      <div class="lp-row"><span class="lp-dot spin-d" id="dot-sr"></span>SportSRC</div>
      <div class="lp-row"><span class="lp-dot spin-d" id="dot-dl"></span>DaddyLive Schedule</div>
    </div>`;
}
function setDot(id, state) {
  const d = document.getElementById('dot-'+id);
  if(d){ d.className='lp-dot '+(state==='done'?'done':'fail'); }
}

// ── Streamed.pk & WeStream.su (same structure) ─
async function loadStreamed(api) {
  const A = api==='sk' ? APIS.SK : APIS.WS;
  let data = await tryFetch(A.base+A.live);
  if(!Array.isArray(data)||!data.length) data = await tryFetch(A.base+A.today);
  if(!Array.isArray(data)) return [];
  return data.map(m=>normalizeStreamed(m, api));
}

// ── SportSRC ──────────────────────────────────
async function loadSportsRC() {
  const results = await Promise.allSettled(
    APIS.SR.cats.map(cat => tryFetch(APIS.SR.base+APIS.SR.matches(cat)))
  );
  const all = [];
  results.forEach(r => {
    if(r.status==='fulfilled'&&Array.isArray(r.value))
      r.value.forEach(m=>{if(m?.id)all.push(normalizeSportsRC(m));});
  });
  return all;
}

// ── DaddyLive schedule ────────────────────────
async function loadDaddy() {
  const data = await tryFetch(APIS.DL.schedule);
  if(!data||typeof data!=='object') return [];
  const out = [];
  // schedule structure: { "Monday 1 Jan": { "Football": [{event,channels:[...]}] } }
  for(const dayVal of Object.values(data)) {
    if(typeof dayVal!=='object') continue;
    for(const [catKey, events] of Object.entries(dayVal)) {
      if(!Array.isArray(events)) continue;
      events.forEach(ev => {
        if(!Array.isArray(ev.channels)) return;
        ev.channels.slice(0,2).forEach(ch => {  // max 2 channels per event to avoid duplication
          if(ch.channel_id) out.push(normalizeDaddy(ev, ch));
        });
      });
    }
  }
  return out;
}

// ══════════════════════════════════════════════
//  SIDEBAR
// ══════════════════════════════════════════════
function buildSidebar(matches) {
  const counts = {};
  matches.forEach(m=>{const c=m.category;if(c)counts[c]=(counts[c]||0)+1;});
  const el = document.getElementById('sportLinks');
  el.innerHTML='';
  Object.entries(counts).sort((a,b)=>b[1]-a[1]).forEach(([id,count])=>{
    if(id==='other'&&count<3) return; // skip tiny "other" bucket
    const btn=document.createElement('button');
    btn.className='sb-link';btn.id='sb-'+id;
    btn.innerHTML=`<span class="sb-icon">${icon(id,16)}</span><span class="sb-text">${cap(id)}</span><span class="sb-count">${count}</span>`;
    btn.onclick=()=>setSport(id,btn);
    el.appendChild(btn);
  });
}

function setSport(sport,el){currentSport=sport;document.querySelectorAll('.sb-link').forEach(b=>b.classList.remove('active'));el.classList.add('active');document.getElementById('searchInput').value='';applyFilter();}
function setNav(mode,el){navMode=mode;document.querySelectorAll('.tnl').forEach(b=>b.classList.remove('active'));el.classList.add('active');applyFilter();}
function resetView(){navMode='live';currentSport='all';document.querySelectorAll('.sb-link').forEach(b=>b.classList.remove('active'));document.getElementById('sb-all')?.classList.add('active');document.querySelectorAll('.tnl').forEach(b=>b.classList.remove('active'));document.getElementById('tnl-live')?.classList.add('active');document.getElementById('searchInput').value='';applyFilter();}

let searchTimer;
document.getElementById('searchInput').addEventListener('input',()=>{clearTimeout(searchTimer);searchTimer=setTimeout(applyFilter,200);});

// ══════════════════════════════════════════════
//  FILTER & RENDER
// ══════════════════════════════════════════════
function applyFilter(){
  const q=document.getElementById('searchInput').value.toLowerCase().trim();
  if(navMode==='mylist'){filteredMatches=myList.filter(m=>!q||m.title?.toLowerCase().includes(q));renderRows(true);return;}
  filteredMatches=allMatches.filter(m=>{
    const ms=currentSport==='all'||m.category===currentSport;
    const mq=!q||m.title?.toLowerCase().includes(q)||m.category?.includes(q);
    const mp=navMode!=='popular'||m.popular;
    return ms&&mq&&mp;
  });
  renderRows(false);
}

function renderRows(isML){
  const container=document.getElementById('rowsContainer');
  if(!filteredMatches.length){container.innerHTML=`<div class="empty-state"><div class="empty-icon">${icon('default',48)}</div>${isML?'No matches saved yet.':'No live matches found.'}</div>`;return;}
  if(isML){
    container.innerHTML='';
    const wrap=document.createElement('div');wrap.className='rows-area';
    const sec=document.createElement('div');sec.className='row-section';
    sec.innerHTML=`<div class="row-hdr"><div class="row-title"><span class="row-title-icon">${icon('default',18)}</span>My List</div><div class="row-count"><span>${filteredMatches.length}</span> saved</div></div><div class="row-scroll" id="ml-row"></div>`;
    wrap.appendChild(sec);container.appendChild(wrap);
    filteredMatches.forEach(m=>sec.querySelector('#ml-row').appendChild(makeCard(m)));
    return;
  }
  const groups={};
  filteredMatches.forEach(m=>{const c=m.category||'other';if(!groups[c])groups[c]=[];groups[c].push(m);});
  const sorted=Object.entries(groups).sort(([,a],[,b])=>b.filter(m=>m.popular).length-a.filter(m=>m.popular).length||b.length-a.length);
  container.innerHTML='';
  const wrap=document.createElement('div');wrap.className='rows-area';
  sorted.forEach(([cat,ms])=>{
    const sec=document.createElement('div');sec.className='row-section';
    sec.innerHTML=`<div class="row-hdr"><div class="row-title"><span class="row-title-icon">${icon(cat,18)}</span>${cap(cat)}</div><div class="row-count"><span>${ms.length}</span> live</div></div><div class="row-scroll"></div>`;
    wrap.appendChild(sec);
    ms.forEach(m=>sec.querySelector('.row-scroll').appendChild(makeCard(m)));
  });
  container.appendChild(wrap);
}

function srcPill(m){
  if(m._multi) return `<span class="src-pill multi">2+</span>`;
  const cls={'sk':'sk','ws':'ws','sr':'sr','dl':'dl'}[m._api]||'multi';
  const lbl=(m._apiLabel||m._api||'?').toUpperCase();
  return `<span class="src-pill ${cls}">${lbl}</span>`;
}

function makeCard(m){
  const card=document.createElement('div');card.className='match-card';
  const hImg=m.teams?.home?.badge, aImg=m.teams?.away?.badge;
  const hasTeams=!!(hImg||aImg);
  const timeStr=m.date instanceof Date&&!isNaN(m.date)?m.date.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'';
  const teamsHTML=hasTeams
    ?`<div class="mc-teams-row">${hImg?`<img class="mc-badge" src="${hImg}" alt="" onerror="this.style.display='none'"/>`:''}<span class="mc-vs">VS</span>${aImg?`<img class="mc-badge" src="${aImg}" alt="" onerror="this.style.display='none'"/>`:''}  </div>`
    :`<div class="mc-placeholder">${icon(m.category,38)}</div>`;
  card.innerHTML=`
    <div class="mc-poster">
      ${m.poster?`<img class="mc-poster-bg" src="${m.poster}" alt="" onerror="this.style.display='none'"/>`:''}
      <div class="mc-poster-shade"></div>
      ${teamsHTML}
      <span class="mc-live-tag">LIVE</span>
      <div class="mc-src-wrap">${srcPill(m)}</div>
    </div>
    <div class="mc-body">
      <div class="mc-title">${m.title}</div>
      <div class="mc-meta">
        <span>${cap(m.category)}</span>
        ${timeStr?`<span class="mc-dot"></span><span>${timeStr}</span>`:''}
        ${m.popular?`<span class="mc-dot"></span><span class="mc-pop"><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Hot</span>`:''}
      </div>
    </div>`;
  card.addEventListener('click',()=>openDetail(m));
  return card;
}

// ══════════════════════════════════════════════
//  HERO
// ══════════════════════════════════════════════
function setHero(m){
  heroMatch=m;
  document.getElementById('heroBg').style.backgroundImage=m.poster?`url(${m.poster})`:'none';
  document.getElementById('heroTitle').textContent=m.title||'Live Match';
  document.getElementById('heroCat').textContent=cap(m.category||'Sport');
  const hImg=m.teams?.home?.badge,aImg=m.teams?.away?.badge;
  document.getElementById('heroTeams').innerHTML=(hImg||aImg)
    ?`${hImg?`<img class="hero-badge-img" src="${hImg}" alt="" onerror="this.style.display='none'"/>`:''}<span class="hero-vs">VS</span>${aImg?`<img class="hero-badge-img" src="${aImg}" alt="" onerror="this.style.display='none'"/>`:''}  `:'';
  const t=m.date instanceof Date&&!isNaN(m.date)?m.date:new Date();
  const srcN=m.sources?.length||(m._api==='sr'?1:m._api==='dl'?1:0);
  document.getElementById('heroMeta').innerHTML=`<span>${cap(m.category||'Sport')}</span><span class="hero-sep"></span><span>${t.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}</span>${srcN?`<span class="hero-sep"></span><span>${srcN} stream${srcN>1?'s':''}</span>`:''}`;
}
function heroPlay(){if(heroMatch)openPlayer(heroMatch);}
function heroDetails(){if(heroMatch)openDetail(heroMatch);}

// ══════════════════════════════════════════════
//  STREAM FETCHING — all 4 APIs
// ══════════════════════════════════════════════
async function fetchStreams(m) {
  const streams=[];

  // 1. Streamed.pk / WeStream.su style
  if((m._api==='sk'||m._api==='ws')&&m.sources?.length&&m._streamPath) {
    const base=m._apiBase||(m._api==='sk'?APIS.SK.base:APIS.WS.base);
    const res=await Promise.allSettled(m.sources.map(s=>tryFetch(base+m._streamPath(s.source,s.id))));
    res.forEach((r,i)=>{
      if(r.status==='fulfilled'&&Array.isArray(r.value))
        r.value.forEach(st=>{if(st.embedUrl)streams.push({label:st.language||`${cap(m.sources[i].source)} ${st.streamNo||''}`.trim(),hd:!!st.hd,url:st.embedUrl,src:m._api==='sk'?'Streamed.pk':'WeStream.su'});});
    });
  }

  // 2. SportSRC detail
  if(m._api==='sr'&&m._srId&&m._srCat) {
    const data=await tryFetch(APIS.SR.base+APIS.SR.detail(m._srCat,m._srId));
    if(data?.streams&&Array.isArray(data.streams))
      data.streams.forEach((st,i)=>{const url=st.embed_url||st.embedUrl||st.url||'';if(url)streams.push({label:st.language||st.source||`Stream ${i+1}`,hd:!!(st.hd||st.quality==='HD'),url,src:'SportSRC'});});
    else if(data?.embed_url)
      streams.push({label:'Main Stream',hd:false,url:data.embed_url,src:'SportSRC'});
  }

  // 3. DaddyLive — construct iframe URL directly from channel_id
  if(m._api==='dl'&&m._dlId) {
    const base=APIS.DL.streamUrl(m._dlId);
    // Try a couple of folder variants
    streams.push({label:'DaddyLive Stream',hd:false,url:base,src:'DaddyLive'});
    streams.push({label:'Mirror',hd:false,url:`https://dlstreams.top/watch/stream-${m._dlId}.php`,src:'DaddyLive'});
  }

  // 4. For multi-source matches — also try the original SK sources if any were attached
  if(m._multi&&m.sources?.length&&m._api!=='sk'&&m._api!=='ws') {
    const res=await Promise.allSettled(m.sources.map(s=>tryFetch(APIS.SK.base+APIS.SK.stream(s.source,s.id))));
    res.forEach((r,i)=>{
      if(r.status==='fulfilled'&&Array.isArray(r.value))
        r.value.forEach(st=>{if(st.embedUrl&&!streams.find(x=>x.url===st.embedUrl))streams.push({label:st.language||`Streamed ${st.streamNo||''}`.trim(),hd:!!st.hd,url:st.embedUrl,src:'Streamed.pk'});});
    });
  }

  return streams;
}

// ══════════════════════════════════════════════
//  DETAIL MODAL
// ══════════════════════════════════════════════
async function openDetail(m){
  detailMatch=m;
  document.getElementById('dmBg').style.backgroundImage=m.poster?`url(${m.poster})`:'none';
  const hImg=m.teams?.home?.badge,aImg=m.teams?.away?.badge;
  document.getElementById('dmTeams').innerHTML=(hImg||aImg)
    ?`${hImg?`<img class="dm-badge" src="${hImg}" alt="" onerror="this.style.opacity='0'"/>`:''}<span class="dm-vs-text">VS</span>${aImg?`<img class="dm-badge" src="${aImg}" alt="" onerror="this.style.opacity='0'"/>`:''}  `
    :`<div class="dm-placeholder">${icon(m.category,64)}</div>`;
  document.getElementById('dmCat').textContent=cap(m.category||'Sport');
  document.getElementById('dmTitle').textContent=m.title||'Unknown';
  const d=m.date instanceof Date&&!isNaN(m.date)?m.date:new Date();
  document.getElementById('dmDate').innerHTML=`<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>${d.toLocaleDateString([],{weekday:'short',month:'short',day:'numeric'})} · ${d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}`;
  const stats=[];
  if(m.teams?.home?.name)stats.push({l:'Home',v:m.teams.home.name});
  if(m.teams?.away?.name)stats.push({l:'Away',v:m.teams.away.name});
  stats.push({l:'Sport',v:cap(m.category||'Sport')});
  stats.push({l:'Source',v:m._multi?'Multiple APIs':({'sk':'Streamed.pk','ws':'WeStream.su','sr':'SportSRC','dl':'DaddyLive'}[m._api]||m._api)});
  document.getElementById('dmStats').innerHTML=stats.map(s=>`<div class="dm-stat"><div class="dm-stat-label">${s.l}</div><div class="dm-stat-val">${s.v}</div></div>`).join('');
  updateMyListBtn();
  document.getElementById('dmStreams').innerHTML=`<div class="streams-title"><div class="spinner" style="width:14px;height:14px;border-width:2px;display:inline-block;vertical-align:middle;margin-right:.4rem"></div>Loading streams…</div>`;
  document.getElementById('detailBg').classList.add('open');
  document.body.style.overflow='hidden';
  const streams=await fetchStreams(m);
  renderDetailStreams(streams,m);
}

function renderDetailStreams(streams,m){
  const el=document.getElementById('dmStreams');
  if(!streams.length){el.innerHTML='<div class="streams-title">No streams available right now</div>';return;}
  let html=`<div class="streams-title"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>Available Streams (${streams.length})</div>`;
  streams.forEach(st=>{
    const safeUrl=(st.url||'').replace(/'/g,"\\'");
    const safeTitle=(m.title||'').replace(/'/g,"\\'");
    const safeLbl=(st.label||'Stream').replace(/'/g,"\\'");
    html+=`<div class="stream-option">
      <div class="so-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5,3 19,12 5,21"/></svg></div>
      <div class="so-info"><div class="so-name">${st.label}${st.hd?' <span style="font-size:.55rem;color:#5aaeff;font-weight:800;font-family:JetBrains Mono,monospace">HD</span>':''}</div><div class="so-sub">${st.src}</div></div>
      <button class="so-play" onclick="playStream('${safeUrl}','${safeTitle}','${safeLbl}')"><svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>Watch</button>
    </div>`;
  });
  el.innerHTML=html;
}

function closeDetail(){document.getElementById('detailBg').classList.remove('open');document.body.style.overflow='';}
function bgClose(e){if(e.target===document.getElementById('detailBg'))closeDetail();}
function playFromDetail(){if(!detailMatch)return;closeDetail();openPlayer(detailMatch);}

// ══════════════════════════════════════════════
//  PLAYER
// ══════════════════════════════════════════════
async function openPlayer(m){
  document.getElementById('phTitle').textContent=m.title||'Match';
  document.getElementById('phSub').textContent=cap(m.category||'Sport');
  document.getElementById('streamBtns').innerHTML='<span style="font-size:.65rem;color:var(--grey);font-family:JetBrains Mono,monospace">Loading…</span>';
  document.getElementById('playerFrame').src='';
  document.getElementById('playerModal').classList.add('open');
  const streams=await fetchStreams(m);
  if(!streams.length){showToast('No streams available');closePlayer();return;}
  const btns=document.getElementById('streamBtns');
  btns.innerHTML='';
  streams.forEach((st,i)=>{
    const btn=document.createElement('button');
    btn.className='stream-btn'+(i===0?' active':'');
    btn.textContent=`${st.label}${st.hd?' HD':''}`;
    btn.onclick=()=>{document.querySelectorAll('.stream-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');document.getElementById('playerFrame').src=st.url;};
    btns.appendChild(btn);
    if(i===0)document.getElementById('playerFrame').src=st.url;
  });
}

function playStream(url,title,label){
  closeDetail();
  document.getElementById('phTitle').textContent=title;
  document.getElementById('phSub').textContent=label;
  document.getElementById('streamBtns').innerHTML=`<button class="stream-btn active">${label}</button>`;
  document.getElementById('playerFrame').src=url;
  document.getElementById('playerModal').classList.add('open');
}
function closePlayer(){document.getElementById('playerModal').classList.remove('open');document.getElementById('playerFrame').src='';}

// ══════════════════════════════════════════════
//  MY LIST
// ══════════════════════════════════════════════
function toggleMyList(){
  if(!detailMatch)return;
  const idx=myList.findIndex(m=>m._id===detailMatch._id);
  if(idx>-1){myList.splice(idx,1);showToast('Removed from My List');}
  else{myList.push({...detailMatch});showToast('Added to My List');}
  saveList();updateMyListBtn();updateMyListCount();
}
function updateMyListBtn(){
  if(!detailMatch)return;
  const inList=myList.some(m=>m._id===detailMatch._id);
  document.getElementById('myListBtn').classList.toggle('added',inList);
  document.getElementById('mlTxt').textContent=inList?'In My List':'My List';
  document.getElementById('mlIco').innerHTML=inList?'<polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2.5" fill="none"/>':`<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>`;
}
function updateMyListCount(){document.getElementById('mylist-count').textContent=myList.length;}

// ── Toast ──
let toastT;
function showToast(msg){document.getElementById('toastMsg').textContent=msg;document.getElementById('toast').classList.add('show');clearTimeout(toastT);toastT=setTimeout(()=>document.getElementById('toast').classList.remove('show'),2600);}

document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    if(document.getElementById('playerModal').classList.contains('open'))closePlayer();
    else if(document.getElementById('detailBg').classList.contains('open'))closeDetail();
  }
});

init();
</script>
